<% content_for :title, "Design Queue" %>

<section class="design-dark-panel border-2 border-dotted p-6">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="font-mono text-xs font-black uppercase tracking-[0.35em] text-pink-300">opportunities // design queue</p>
      <h1 class="mt-3 font-mono text-4xl font-black tracking-[-0.06em] text-white">Design Queue</h1>
      <p class="mt-4 max-w-3xl font-mono text-sm leading-7 text-zinc-300">
        Current design queue from the latest TRAIN upload. Missing rows from a new CSV are marked COMPLETE and removed from this queue.
      </p>
    </div>
    <%= link_to "UPLOAD IN TRAIN", train_path(anchor: "design-reports"), class: "design-soft-button border border-dotted border-white/50 px-5 py-3 font-mono text-[11px] font-black text-white" %>
  </div>
</section>

<section class="mt-6 grid gap-4 sm:grid-cols-3">
  <div class="border border-dotted border-green-300/80 bg-green-950/35 p-4 shadow-lg shadow-green-950/30">
    <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-green-200">green // &lt; 1 day</p>
    <strong class="mt-2 block font-mono text-4xl text-green-100"><%= number_with_delimiter(@queue_green_count) %></strong>
  </div>
  <div class="border border-dotted border-orange-300/80 bg-orange-950/35 p-4 shadow-lg shadow-orange-950/30">
    <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-orange-200">orange // 1-2 days</p>
    <strong class="mt-2 block font-mono text-4xl text-orange-100"><%= number_with_delimiter(@queue_orange_count) %></strong>
  </div>
  <div class="border border-dotted border-teal-400/80 bg-teal-950/45 p-4 shadow-lg shadow-teal-950/40">
    <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-teal-200">red // 3+ days</p>
    <strong class="mt-2 block font-mono text-4xl text-teal-100"><%= number_with_delimiter(@queue_red_count) %></strong>
  </div>
</section>

<section class="mt-4 flex flex-wrap gap-3 font-mono text-[10px] uppercase tracking-[0.22em] text-zinc-400">
  <span class="border border-dotted border-white/30 bg-white/5 px-3 py-2">queue total // <%= number_with_delimiter(@queue_count) %></span>
  <span class="border border-dotted border-white/30 bg-white/5 px-3 py-2">complete // <%= number_with_delimiter(@complete_count) %></span>
  <span class="border border-dotted border-white/30 bg-white/5 px-3 py-2">all records // <%= number_with_delimiter(@total_design_order_count) %></span>
</section>

<section class="design-dark-panel mt-6 border border-dotted p-5">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="font-mono text-[10px] font-black uppercase tracking-[0.35em] text-teal-500">design objects</p>
      <h2 class="mt-2 font-mono text-2xl font-black text-white">Queued design orders</h2>
    </div>
    <%= form_with url: design_reports_path, method: :get, class: "flex min-w-72 flex-1 flex-wrap justify-end gap-3" do |form| %>
      <%= form.search_field :q, value: params[:q], placeholder: "Search order, customer, designer, product", class: "min-w-72 flex-1 border border-dotted border-white/40 bg-[#090909] px-4 py-3 text-white" %>
      <%= form.submit "Search", class: "design-soft-button border border-dotted border-white/50 px-5 py-3 font-mono text-[11px] font-black text-white" %>
    <% end %>
  </div>

  <div class="mt-6 overflow-hidden border border-dotted border-white/40">
    <% @design_orders.each do |order| %>
      <%= link_to design_order_path(order), class: "design-hover-tile grid gap-2 border-b border-dotted border-white/20 p-4 md:grid-cols-[120px_1fr_180px_150px_110px]" do %>
        <span class="font-mono text-xs uppercase tracking-[0.2em] text-pink-300">#<%= order.order_number.presence || order.id %></span>
        <strong><%= order.item_name %></strong>
        <span class="text-zinc-300"><%= order.product_name.presence || "product unknown" %></span>
        <span class="text-zinc-300"><%= order.designer_name.presence || "unassigned" %></span>
        <span class="text-zinc-400"><%= pluralize(order.revisions, "revision") %></span>
      <% end %>
    <% end %>
    <% if @design_orders.blank? %>
      <p class="p-6 text-zinc-300">No queued design orders match this view.</p>
    <% end %>
  </div>
</section>

<section class="mt-6 grid gap-4 lg:grid-cols-[1fr_1fr]">
  <div class="design-dark-panel border border-dotted p-5">
    <p class="font-mono text-[10px] font-black uppercase tracking-[0.35em] text-teal-500">recent uploads</p>
    <div class="mt-5 grid gap-3">
      <% @recent_reports.each do |report| %>
        <%= link_to design_report_path(report), class: "design-hover-tile block border border-dotted border-white/30 p-4" do %>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-pink-300"><%= report.status %> // <%= report.row_count %> rows</p>
          <strong class="mt-2 block text-white"><%= report.display_title %></strong>
          <span class="mt-1 block text-sm text-zinc-400"><%= report.user.display_name %> // <%= report.created_at.strftime("%b %-d, %Y %l:%M %p %Z") %></span>
        <% end %>
      <% end %>
      <% if @recent_reports.blank? %>
        <p class="design-dark-panel border border-dotted p-4 text-zinc-300">No design reports imported yet.</p>
      <% end %>
    </div>
  </div>

  <div class="grid gap-3 sm:grid-cols-2">
    <div class="design-dark-panel border border-dotted p-4">
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-zinc-400">products</p>
      <% @product_counts.each do |product, count| %>
        <p class="mt-2 flex justify-between gap-3 text-sm"><span><%= product.presence || "Unknown" %></span><strong><%= count %></strong></p>
      <% end %>
    </div>
    <div class="design-dark-panel border border-dotted p-4">
      <p class="font-mono text-[10px] uppercase tracking-[0.22em] text-zinc-400">designers</p>
      <% @designer_counts.each do |designer, count| %>
        <p class="mt-2 flex justify-between gap-3 text-sm"><span><%= designer.presence || "Unknown" %></span><strong><%= count %></strong></p>
      <% end %>
    </div>
  </div>
</section>
