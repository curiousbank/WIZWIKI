        linear-gradient(135deg, rgba(34, 211, 238, 0.08), rgba(255, 45, 98, 0.08)),
        rgba(0, 0, 0, 0.42);
      padding: clamp(12px, 2vw, 18px);
      box-shadow: inset 0 0 24px rgba(34, 211, 238, 0.05), 0 0 28px rgba(255, 45, 98, 0.1);
    }

    .wizwiki-usage-head,
    .wizwiki-usage-metrics,
    .wizwiki-usage-memory,
    .wizwiki-usage-split,
    .wizwiki-usage-days,
    .wizwiki-usage-grid {
      display: grid;
      gap: 8px;
    }

    .wizwiki-usage-head {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: end;
    }

    .wizwiki-usage-head span,
    .wizwiki-usage-head small,
    .wizwiki-usage-metrics span,
    .wizwiki-usage-metrics small,
    .wizwiki-usage-memory span,
    .wizwiki-usage-memory small,
    .wizwiki-usage-insight span,
    .wizwiki-usage-insight small,
    .wizwiki-usage-days span {
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.14em;
      line-height: 1.25;
      text-transform: uppercase;
    }

    .wizwiki-usage-head span,
    .wizwiki-usage-insight span {
      color: #7cff9b;
    }

    .wizwiki-usage-head strong {
      color: white;
      font-size: 13px;
      text-align: right;
      text-transform: uppercase;
    }

    .wizwiki-usage-head small {
      grid-column: 1 / -1;
      color: rgba(247, 247, 242, 0.62);
    }

    .wizwiki-usage-metrics {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .wizwiki-usage-memory {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .wizwiki-usage-metrics div,
    .wizwiki-usage-memory div,
    .wizwiki-usage-insight {
      border: 1px dotted rgba(247, 247, 242, 0.22);
      background: rgba(0, 0, 0, 0.34);
      padding: 9px;
    }

    .wizwiki-usage-metrics strong,
    .wizwiki-usage-memory strong {
      display: block;
      color: white;
      font-size: clamp(1.1rem, 2.5vw, 1.7rem);
      line-height: 0.95;
      overflow-wrap: anywhere;
      text-shadow: 0 0 13px rgba(34, 211, 238, 0.22);
    }

    .wizwiki-usage-memory strong {
      font-size: clamp(0.9rem, 1.8vw, 1.25rem);
      line-height: 1.15;
    }

    .wizwiki-usage-metrics span,
    .wizwiki-usage-memory span,
    .wizwiki-usage-days span {
      color: rgba(247, 247, 242, 0.72);
    }

    .wizwiki-usage-metrics small,
    .wizwiki-usage-memory small,
    .wizwiki-usage-insight small {
      color: rgba(247, 247, 242, 0.48);
    }

    .wizwiki-usage-split {
      grid-template-columns: minmax(0, 1fr) minmax(180px, 0.72fr);
      align-items: start;
    }

    .wizwiki-usage-insight p {
      margin: 5px 0 7px;
      color: rgba(247, 247, 242, 0.84);
      font-size: 13px;
      line-height: 1.45;
    }

    .wizwiki-usage-days,
    .wizwiki-usage-grid {
      grid-template-columns: repeat(7, minmax(0, 1fr));
    }

    .wizwiki-usage-day {
      display: grid;
      min-height: 23px;
      place-items: center;
      border: 1px dotted rgba(247, 247, 242, 0.2);
      background: rgba(255, 255, 255, 0.035);
      color: rgba(247, 247, 242, 0.56);
      font-size: 11px;
      font-weight: 900;
    }

    .wizwiki-usage-day--1 { background: rgba(124, 255, 155, 0.12); color: white; }
    .wizwiki-usage-day--2 { background: rgba(34, 211, 238, 0.18); color: white; }
    .wizwiki-usage-day--3 { background: rgba(255, 45, 98, 0.22); color: white; }
    .wizwiki-usage-day--4 { background: linear-gradient(135deg, rgba(124, 255, 155, 0.52), rgba(255, 45, 98, 0.5)); color: #050505; }
    .wizwiki-usage-day--blank { opacity: 0; }

    @keyframes wizwikiAskProgress { from { transform: translateX(-100%); } to { transform: translateX(260%); } }
    @keyframes wizwikiBlink { 50% { opacity: 0.18; } }

    @media (max-width: 900px) {
      .wizwiki-ask-hero { grid-template-columns: 1fr; }
      .wizwiki-ask-hero-status {
        border-left: 0;
        border-top: 1px dotted rgba(247, 247, 242, 0.24);
        padding-top: 8px;
        padding-left: 0;
      }
      .wizwiki-ask-grid { grid-template-columns: 1fr; }
      .wizwiki-usage-metrics,
      .wizwiki-usage-memory,
      .wizwiki-usage-split { grid-template-columns: 1fr; }
      .wizwiki-ask-controls {
        grid-template-columns: minmax(0, 1fr) minmax(150px, 1fr) minmax(0, 1fr);
        grid-template-areas:
          "full ask walkie"
          ". stop .";
      }
      .wizwiki-answer-stream { max-height: none; }
    }

    @media (max-width: 540px) {
      .wizwiki-ask-controls {
        grid-template-columns: 1fr;
        grid-template-areas:
          "ask"
          "full"
          "walkie"
          "stop";
      }
      .wizwiki-ask-controls--autopilot {
        grid-template-columns: 1fr;
        grid-template-areas:
          "ask"
          "dojo";
      }
      .wizwiki-answer-meta, .wizwiki-answer-output-head { display: grid; }
      .wizwiki-ask-sms-bubble { max-width: 100%; }
      .wizwiki-ask-dojo-grade,
      .wizwiki-ask-dojo-summary { grid-template-columns: 1fr; }
    }
  </style>
  <script>
    (() => {
      const copyScriptVersion = "copy-thread-asc-2026-06-30.3"
      if (window.__wizwikiAskCopyButtons === copyScriptVersion) return
      window.__wizwikiAskCopyButtons = copyScriptVersion

      const threadText = (button) => {
        const root = document.querySelector(button.dataset.wizwikiCopyThread)
        if (!root) return ""

        const rows = Array.from(root.querySelectorAll("[data-wizwiki-copy-line]")).map((node, index) => ({
          index,
          text: node.dataset.wizwikiCopyLine || node.textContent.trim(),
          time: Date.parse(node.dataset.wizwikiCopyTime || "")
        }))

        const sortByTime = (direction) => {
          rows.sort((left, right) => {
            const leftTimed = Number.isFinite(left.time)
            const rightTimed = Number.isFinite(right.time)
            if (leftTimed && rightTimed && left.time !== right.time) {
              return direction === "asc" ? left.time - right.time : right.time - left.time
            }
            if (leftTimed !== rightTimed) return leftTimed ? -1 : 1
            return direction === "asc" ? left.index - right.index : right.index - left.index
          })
        }

        if (button.dataset.wizwikiCopyReverse === "true") {
          if (rows.every((row) => Number.isFinite(row.time))) {
            sortByTime("asc")
          } else {
            rows.reverse()
          }
        } else if (button.dataset.wizwikiCopyOrder === "desc") {
          sortByTime("desc")
        } else if (button.dataset.wizwikiCopyOrder === "asc") {
          sortByTime("asc")
        }

        return rows
          .map((row) => row.text)
          .filter(Boolean)
          .join("\n\n")
      }

      const writeClipboard = async (text) => {
        if (navigator.clipboard?.writeText && window.isSecureContext) {
          try {
            await navigator.clipboard.writeText(text)
            return
          } catch (_error) {
            // Fall through to the textarea fallback when the Clipboard API is exposed but blocked.
          }
        }

        const field = document.createElement("textarea")
        field.value = text
        field.setAttribute("readonly", "readonly")
        field.style.position = "fixed"
        field.style.top = "0"
        field.style.left = "-9999px"
        field.style.opacity = "0"
        document.body.appendChild(field)
        field.focus({ preventScroll: true })
        field.select()
        field.setSelectionRange(0, field.value.length)
        const copied = document.execCommand("copy")
        field.remove()
        if (!copied) throw new Error("Clipboard copy command was rejected")
      }

      const flash = (button) => {
        const original = button.dataset.copyOriginalLabel || button.textContent
        button.dataset.copyOriginalLabel = original
        button.textContent = "COPIED"
        window.clearTimeout(button._copyResetTimer)
        button._copyResetTimer = window.setTimeout(() => {
          button.textContent = button.dataset.copyOriginalLabel || original
        }, 1200)
      }

      const primeDojoForm = (form) => {
        if (!(form instanceof HTMLFormElement)) return
        const scope = form.closest("[data-wizwiki-dojo-scope]") || document
        const guidanceSource = scope.querySelector("[data-wizwiki-dojo-guidance-source]")
        const guidanceInput = form.querySelector("[data-wizwiki-dojo-guidance-input]")
        const modelSource = scope.querySelector("[data-wizwiki-dojo-model-source]")
        const modelInput = form.querySelector("[data-wizwiki-dojo-model-input]")
        if (guidanceInput && guidanceSource) guidanceInput.value = guidanceSource.value || ""
        if (modelInput && modelSource) modelInput.value = modelSource.value || modelInput.value || ""
      }

      const handleCopyClick = async (event) => {
        const target = event.target instanceof Element ? event.target : event.target?.parentElement
        const button = target?.closest?.("[data-wizwiki-copy-text], [data-wizwiki-copy-thread]")
        if (!button) return

        event.preventDefault()
        event.stopImmediatePropagation()
        const text = button.dataset.wizwikiCopyText || threadText(button)
        if (!text) return

        try {
          await writeClipboard(text)
          flash(button)
        } catch (error) {
          console.warn("Could not copy Thumper text", error)
        }
      }

      if (window.__wizwikiAskCopyClickHandler) {
        document.removeEventListener("click", window.__wizwikiAskCopyClickHandler, true)
      }
      window.__wizwikiAskCopyClickHandler = handleCopyClick
      document.addEventListener("click", handleCopyClick, true)

      document.addEventListener("click", (event) => {
        const target = event.target instanceof Element ? event.target : event.target?.parentElement
        const dojoButton = target?.closest?.("[data-wizwiki-dojo-submit]")
        if (dojoButton) primeDojoForm(dojoButton.form)
      })

      document.addEventListener("submit", (event) => {
        const form = event.target
        if (form instanceof HTMLFormElement && form.matches("[data-wizwiki-dojo-form]")) primeDojoForm(form)
      }, true)
    })()
  </script>
<% end %>

<section class="wizwiki-ask-console" data-controller="autos-talk" data-autos-talk-ask-url-value="<%= ask_path(format: :turbo_stream) %>">
  <% hero_test = @ask_autopilot_test.respond_to?(:to_h) ? @ask_autopilot_test.to_h : {} %>
  <% hero_active = Comms::AskAutopilotTest.active?(hero_test) %>
  <% hero_pending = hero_active && ActiveModel::Type::Boolean.new.cast(hero_test["pending"]) %>
  <% hero_pending_started_at = hero_test["pending_started_at"].presence || hero_test["updated_at"].presence %>
  <% hero_ask_question = Array(@recent_questions).find { |question| question.respond_to?(:ask_refresh_pending?) && question.ask_refresh_pending? } %>
  <% hero_ask_pending = hero_ask_question.present? %>
  <% hero_ask_started_at = hero_ask_question&.created_at&.iso8601 %>
  <% sms_thread_selected = hero_active || !hero_ask_pending %>
  <% hero_sms_pending_label = hero_test["pending_label"].presence || "SMS simulator drafting" %>
  <% hero_sms_ready_label = hero_active ? "SMS simulator ready" : "SMS simulator idle" %>
  <% hero_sms_ready_note = hero_active ? hero_test["engine_label"].presence || "real engine // no twilio" : "start an SMS sim to test" %>
  <% hero_ask_pending_label = "Ask thread drafting" %>
  <% hero_ask_ready_label = "Ask thread ready" %>
  <% hero_status_label = sms_thread_selected ? (hero_pending ? hero_sms_pending_label : hero_sms_ready_label) : (hero_ask_pending ? hero_ask_pending_label : hero_ask_ready_label) %>
  <% hero_status_note =
    if sms_thread_selected
      hero_pending ? "live draft signals" : hero_sms_ready_note
    else
      hero_ask_pending ? "Thumper answer stream active" : "Thumper vector context ready"
    end %>

  <div class="wizwiki-ask-hero <%= "is-drafting" if hero_pending || hero_ask_pending %>"
       data-wizwiki-ask-hero
       data-sms-ready-label="<%= hero_sms_ready_label %>"
       data-sms-ready-note="<%= hero_sms_ready_note %>"
       data-sms-pending-label="<%= hero_sms_pending_label %>"
       data-sms-pending-note="live draft signals"
       data-ask-ready-label="<%= hero_ask_ready_label %>"
       data-ask-ready-note="Thumper vector context ready"
       data-ask-pending-label="<%= hero_ask_pending_label %>"
       data-ask-pending-note="Thumper answer stream active">
    <div class="wizwiki-ask-hero-main">
      <p class="wizwiki-ask-kicker">WIZWIKI // Thumper</p>
      <h1 class="wizwiki-ask-title">Thumper</h1>
    </div>
    <div class="wizwiki-ask-hero-status" <% if hero_pending || hero_ask_pending %>role="status" aria-live="polite"<% end %>>
      <div class="wizwiki-ask-hero-status-head">
        <strong data-wizwiki-hero-label><%= hero_status_label %></strong>
        <span data-wizwiki-hero-note><%= hero_status_note %></span>
      </div>
      <div class="wizwiki-ask-hero-progress-stack">
        <div class="wizwiki-ask-hero-progress wizwiki-ask-hero-progress--sms <%= "hidden" unless hero_pending %>" data-wizwiki-hero-sms-progress data-ask-autopilot-thinking data-ask-autopilot-thinking-started-at="<%= hero_pending_started_at %>">
          <div class="wizwiki-ask-hero-progress-head">
            <b>SMS Sim</b>
            <span data-ask-autopilot-thinking-timer>00:00</span>
          </div>
          <div class="wizwiki-ask-autopilot-thinking-bar">
            <span data-ask-autopilot-thinking-bar></span>
          </div>
        </div>
        <div class="wizwiki-ask-hero-progress wizwiki-ask-hero-progress--ask <%= "hidden" unless hero_ask_pending %>" data-wizwiki-hero-ask-progress data-wizwiki-processing-since="<%= hero_ask_started_at %>">
          <div class="wizwiki-ask-hero-progress-head">
            <b>Ask Thread</b>
            <span data-wizwiki-processing-timer>00:00</span>
          </div>
          <div class="wizwiki-processing-progress" aria-hidden="true">
            <i data-wizwiki-processing-bar></i>
          </div>
        </div>
      </div>
      <%= render "hero_sms_telemetry", ask_autopilot_test: @ask_autopilot_test %>
    </div>
  </div>

  <%= render "usage_review", usage_review: @usage_review %>

  <div class="wizwiki-ask-grid">
    <div class="wizwiki-ask-panel">
      <div id="autos_question_form">
        <%= render "form", autos_question: @autos_question, ask_autopilot_test: @ask_autopilot_test %>
      </div>
    </div>

    <div class="wizwiki-ask-panel">
      <div class="wizwiki-thread-console">
        <input id="wizwiki-thread-sms" class="wizwiki-thread-radio" type="radio" name="wizwiki_thread_view" <%= "checked" if sms_thread_selected %>>
        <input id="wizwiki-thread-ask" class="wizwiki-thread-radio" type="radio" name="wizwiki_thread_view" <%= "checked" unless sms_thread_selected %>>

        <div class="wizwiki-answer-meta">
          <span>thread view</span>
          <span>choose one active thread</span>
        </div>

        <div class="wizwiki-thread-toggle" role="tablist" aria-label="Thumper thread view">
          <label for="wizwiki-thread-sms" role="tab">SMS Simulator</label>
          <label for="wizwiki-thread-ask" role="tab">Ask Thread</label>
        </div>

        <div class="wizwiki-thread-panels">
          <div class="wizwiki-thread-panel wizwiki-thread-panel--sms" role="tabpanel" aria-label="SMS simulator thread">
            <%= render "autopilot_test", ask_autopilot_test: @ask_autopilot_test %>
          </div>

          <div class="wizwiki-thread-panel wizwiki-thread-panel--ask" role="tabpanel" aria-label="Ask thread">
            <div class="wizwiki-answer-meta">
              <span>answer stream</span>
              <span>Thumper vector context -> Qwen answer -> guarded retry</span>
              <% if @recent_questions.present? %>
                <button type="button" class="wizwiki-copy-button" data-wizwiki-copy-thread="#autos_questions" data-wizwiki-copy-order="asc">COPY THREAD</button>
              <% end %>
            </div>
            <div id="autos_questions" class="wizwiki-answer-stream" data-controller="autos-questions" data-autos-questions-url-value="<%= ask_questions_path(format: :turbo_stream) %>" data-autos-questions-interval-value="3000">
              <% if @recent_questions.present? %>
                <%= render partial: "question", collection: @recent_questions, as: :question %>
              <% else %>
                <p id="autos_questions_empty" class="border border-dotted border-white/30 bg-white/5 p-4 text-zinc-300">No questions queued yet.</p>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
