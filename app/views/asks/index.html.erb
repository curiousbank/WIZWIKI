<% content_for :title, "WIZWIKI // Thumper" %>
<%= turbo_stream_from "autos_questions_user_#{current_user.id}" if current_user.present? %>

<% content_for :head do %>
  <style>
    .wizwiki-ask-console {
      display: grid;
      gap: 16px;
      color: #f7f7f2;
      font-family: "Courier New", Courier, monospace;
    }

    .wizwiki-ask-hero,
    .wizwiki-ask-panel,
    .wizwiki-answer-card {
      border: 2px dotted rgba(255, 255, 255, 0.42);
      background:
        repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 7px),
        linear-gradient(135deg, rgba(255, 45, 98, 0.13), rgba(8, 8, 8, 0.98) 42%, rgba(124, 255, 155, 0.055));
      box-shadow: inset 0 0 24px rgba(255, 255, 255, 0.04), 0 0 38px rgba(255, 45, 98, 0.12);
    }

    .wizwiki-ask-hero {
      display: grid;
      grid-template-columns: minmax(126px, 0.22fr) minmax(0, 1fr);
      gap: 10px;
      align-items: stretch;
      padding: clamp(10px, 1.5vw, 16px);
    }

    .wizwiki-ask-hero-main {
      display: grid;
      align-content: center;
      gap: 2px;
      min-width: 0;
    }

    .wizwiki-ask-kicker,
    .wizwiki-ask-label,
    .wizwiki-answer-meta,
    .wizwiki-answer-output-head,
    .wizwiki-voice-status {
      font-size: 11px;
      font-weight: 900;
      letter-spacing: 0.18em;
      line-height: 1.4;
      text-transform: uppercase;
    }

    .wizwiki-ask-kicker { color: #7cff9b; }

    .wizwiki-ask-title {
      margin: 0;
      color: white;
      font-size: clamp(1.45rem, 3vw, 2.2rem);
      font-weight: 1000;
      letter-spacing: 0;
      line-height: 1;
      text-shadow: 0 0 18px rgba(124, 255, 155, 0.18), 4px 4px 0 rgba(255, 45, 98, 0.26);
    }

    .wizwiki-ask-hero-status {
      display: grid;
      align-content: center;
      min-width: 0;
      gap: 7px;
      border-left: 1px dotted rgba(247, 247, 242, 0.28);
      padding-left: 10px;
    }

    .wizwiki-ask-hero.is-drafting .wizwiki-ask-hero-status {
      border-left-color: rgba(124, 255, 155, 0.7);
    }

    .wizwiki-ask-hero-status-head {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 12px;
      align-items: baseline;
      justify-content: space-between;
      min-width: 0;
    }

    .wizwiki-ask-hero-status-head strong {
      min-width: 0;
      color: #f7f7f2;
      font-size: 12px;
      font-weight: 1000;
      letter-spacing: 0.08em;
      line-height: 1.2;
      overflow-wrap: anywhere;
      text-transform: uppercase;
    }

    .wizwiki-ask-hero-status-head span,
    .wizwiki-ask-hero-status p {
      color: rgba(247, 247, 242, 0.58);
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.12em;
      line-height: 1.35;
      margin: 0;
      text-transform: uppercase;
    }

    .wizwiki-ask-hero.is-drafting .wizwiki-ask-hero-status-head span {
      color: #7cff9b;
    }

    .wizwiki-ask-hero-progress {
      display: grid;
      gap: 5px;
      min-width: 0;
    }

    .wizwiki-ask-hero-progress-stack {
      display: grid;
      gap: 6px;
      min-width: 0;
    }

    .wizwiki-ask-hero-progress {
      border: 1px dotted rgba(247, 247, 242, 0.22);
      background: rgba(0, 0, 0, 0.26);
      padding: 6px 7px;
    }

    .wizwiki-ask-hero-progress-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      color: rgba(247, 247, 242, 0.68);
      font-size: 9px;
      font-weight: 1000;
      letter-spacing: 0.14em;
      line-height: 1.2;
      text-transform: uppercase;
    }

    .wizwiki-ask-hero-progress-head b {
      color: #ff8dae;
      font-size: 9px;
    }

    .wizwiki-ask-hero-progress-head span {
      color: #7cff9b;
      font-variant-numeric: tabular-nums;
      min-width: 46px;
      text-align: right;
    }

    .wizwiki-ask-hero-progress .wizwiki-ask-autopilot-thinking-bar,
    .wizwiki-ask-hero-progress .wizwiki-processing-progress {
      margin-top: 0;
    }

    .wizwiki-ask-hero-progress .wizwiki-processing-progress {
      height: 10px;
    }

    .wizwiki-ask-hero-signals {
      display: grid;
      gap: 3px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .wizwiki-ask-hero-signals li {
      display: grid;
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 8px;
      min-width: 0;
      color: rgba(247, 247, 242, 0.68);
      font-size: 11px;
      line-height: 1.3;
    }

    .wizwiki-ask-hero-signals b {
      color: #ff8dae;
      font-size: 9px;
      font-weight: 1000;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .wizwiki-ask-hero-signals span {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .wizwiki-ask-hero-telemetry {
      min-width: 0;
    }

    .wizwiki-ask-autopilot-telemetry--hero {
      margin-top: 0;
      border-top: 0;
      padding-top: 0;
    }

    .wizwiki-ask-autopilot-telemetry--hero .wizwiki-ask-autopilot-telemetry-chips em {
      max-width: min(420px, 58vw);
    }

    .wizwiki-ask-grid {
      display: grid;
      gap: 16px;
      grid-template-columns: minmax(280px, 0.85fr) minmax(0, 1.15fr);
      align-items: start;
    }

    .wizwiki-ask-panel { padding: clamp(14px, 2vw, 22px); }

    .wizwiki-thread-console {
      display: grid;
      gap: 12px;
    }

    .wizwiki-thread-radio {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
      white-space: nowrap;
    }

    .wizwiki-thread-toggle {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 6px;
      border: 1px dotted rgba(247, 247, 242, 0.22);
      background: rgba(0, 0, 0, 0.26);
      padding: 6px;
    }

    .wizwiki-thread-toggle label {
      display: inline-flex;
      min-height: 38px;
      align-items: center;
      justify-content: center;
      border: 1px dotted rgba(247, 247, 242, 0.28);
      background: rgba(5, 5, 5, 0.82);
      color: rgba(247, 247, 242, 0.66);
      cursor: pointer;
      font-size: 10px;
      font-weight: 1000;
      letter-spacing: 0.14em;
      line-height: 1.2;
      padding: 7px 9px;
      text-align: center;
      text-transform: uppercase;
    }

    .wizwiki-thread-toggle label:hover,
    .wizwiki-thread-toggle label:focus-visible {
      border-color: rgba(124, 255, 155, 0.7);
      color: #f7f7f2;
      outline: none;
    }

    #wizwiki-thread-sms:checked ~ .wizwiki-thread-toggle label[for="wizwiki-thread-sms"],
    #wizwiki-thread-ask:checked ~ .wizwiki-thread-toggle label[for="wizwiki-thread-ask"] {
      border-color: rgba(124, 255, 155, 0.86);
      background: rgba(124, 255, 155, 0.14);
      color: #7cff9b;
      box-shadow: inset 0 0 18px rgba(124, 255, 155, 0.08), 0 0 16px rgba(124, 255, 155, 0.1);
    }

    .wizwiki-thread-panels {
      display: grid;
      gap: 12px;
    }

    .wizwiki-thread-panel {
      display: none;
      min-width: 0;
    }

    #wizwiki-thread-sms:checked ~ .wizwiki-thread-panels .wizwiki-thread-panel--sms,
    #wizwiki-thread-ask:checked ~ .wizwiki-thread-panels .wizwiki-thread-panel--ask {
      display: grid;
      gap: 12px;
    }

    .wizwiki-ask-autopilot {
      display: grid;
      gap: 12px;
      border: 2px dotted rgba(34, 211, 238, 0.42);
      background:
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.03) 0 1px, transparent 1px 9px),
        linear-gradient(135deg, rgba(34, 211, 238, 0.1), rgba(5, 5, 5, 0.96) 46%, rgba(124, 255, 155, 0.08));
      padding: clamp(14px, 2vw, 20px);
      box-shadow: inset 0 0 24px rgba(34, 211, 238, 0.04), 0 0 28px rgba(124, 255, 155, 0.09);
    }

    .wizwiki-ask-autopilot.is-active {
      border-color: rgba(124, 255, 155, 0.62);
    }

    .wizwiki-ask-autopilot-idle,
    .wizwiki-ask-autopilot-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      justify-content: space-between;
    }

    .wizwiki-ask-autopilot-idle p {
      margin: 0;
      color: rgba(247, 247, 242, 0.7);
      font-size: 12px;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-actions {
      justify-content: flex-end;
    }

    .wizwiki-ask-thread-tools,
    .wizwiki-copy-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
    }

    .wizwiki-ask-thread-tools {
      justify-content: flex-end;
    }

    .wizwiki-copy-button {
      border: 1px dotted rgba(124, 255, 155, 0.72);
      border-radius: 0;
      background: rgba(5, 5, 5, 0.84);
      color: #7cff9b;
      cursor: pointer;
      font: inherit;
      font-size: 10px;
      font-weight: 1000;
      letter-spacing: 0.12em;
      line-height: 1;
      padding: 7px 9px;
      text-transform: uppercase;
    }

    .wizwiki-copy-button:hover,
    .wizwiki-copy-button:focus-visible {
      background: rgba(124, 255, 155, 0.15);
      box-shadow: 0 0 14px rgba(124, 255, 155, 0.16);
      outline: none;
    }

    .wizwiki-copy-button--mini {
      padding: 5px 7px;
      font-size: 9px;
    }

    .wizwiki-ask-autopilot-actions form,
    .wizwiki-ask-autopilot-idle form {
      margin: 0;
    }

    .wizwiki-ask-autopilot-action-form {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: end;
      justify-content: flex-end;
      min-width: min(420px, 100%);
    }

    .wizwiki-ask-autopilot-action-form--start {
      justify-content: flex-start;
    }

    .wizwiki-ask-autopilot-button {
      min-height: 40px;
      border: 2px dotted rgba(124, 255, 155, 0.76);
      border-radius: 0;
      background: #050505;
      color: #7cff9b;
      cursor: pointer;
      font: inherit;
      font-size: 11px;
      font-weight: 1000;
      letter-spacing: 0.12em;
      padding: 9px 14px;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-button:hover,
    .wizwiki-ask-autopilot-button:focus-visible {
      background: rgba(124, 255, 155, 0.14);
      box-shadow: inset 0 0 20px rgba(124, 255, 155, 0.12), 0 0 18px rgba(124, 255, 155, 0.14);
    }

    .wizwiki-ask-autopilot-button--muted {
      border-color: rgba(255, 255, 255, 0.34);
      color: rgba(247, 247, 242, 0.72);
    }

    .wizwiki-ask-autopilot-thread {
      display: grid;
      max-height: 360px;
      gap: 10px;
      overflow-anchor: none;
      overflow-y: auto;
      padding: 4px;
      overscroll-behavior: contain;
      scroll-behavior: auto;
    }

    .wizwiki-ask-autopilot-thinking {
      border: 1px dotted rgba(124, 255, 155, 0.7);
      background:
        repeating-linear-gradient(90deg, rgba(124, 255, 155, 0.08) 0 2px, transparent 2px 10px),
        rgba(3, 12, 8, 0.9);
      box-shadow: inset 0 0 22px rgba(124, 255, 155, 0.1), 0 0 20px rgba(124, 255, 155, 0.08);
      padding: 10px 12px;
    }

    .wizwiki-ask-autopilot-thinking-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      color: #f7f7f2;
      font-size: 12px;
      font-weight: 1000;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-thinking-head span {
      color: #7cff9b;
      font-variant-numeric: tabular-nums;
      min-width: 46px;
      text-align: right;
    }

    .wizwiki-ask-autopilot-thinking-bar {
      height: 10px;
      margin-top: 9px;
      overflow: hidden;
      border: 1px solid rgba(247, 247, 242, 0.24);
      background: #050505;
    }

    .wizwiki-ask-autopilot-thinking-bar span {
      display: block;
      width: 14%;
      min-width: 22%;
      height: 100%;
      background: linear-gradient(90deg, #7cff9b, #22d3ee, #ff2d62);
      box-shadow: 0 0 18px rgba(124, 255, 155, 0.5);
      transition: width 0.35s ease;
      animation: wizwikiAskAutopilotPulse 1.2s linear infinite;
    }

    .wizwiki-ask-autopilot-thinking--compact {
      padding: 8px 10px;
    }

    .wizwiki-ask-autopilot-thinking--compact .wizwiki-ask-autopilot-thinking-head {
      font-size: 11px;
    }

    .wizwiki-ask-autopilot-thinking--compact .wizwiki-ask-autopilot-thinking-bar {
      height: 8px;
      margin-top: 7px;
    }

    .wizwiki-ask-dojo-scoreboard {
      display: grid;
      grid-template-columns: minmax(96px, 128px) minmax(0, 1fr);
      gap: 10px;
      align-items: stretch;
      margin: 8px 0 10px;
      border: 1px dotted rgba(247, 247, 242, 0.26);
      background:
        linear-gradient(135deg, rgba(124, 255, 155, 0.12), rgba(34, 211, 238, 0.08) 48%, rgba(255, 45, 98, 0.09)),
        rgba(5, 5, 5, 0.84);
      padding: 10px;
      box-shadow: inset 0 0 18px rgba(247, 247, 242, 0.045);
    }

    .wizwiki-ask-dojo-scoreboard-main {
      display: grid;
      grid-template-columns: auto auto;
      align-content: center;
      justify-content: center;
      gap: 0 3px;
      min-height: 74px;
      border: 1px solid rgba(124, 255, 155, 0.26);
      background: rgba(0, 0, 0, 0.38);
      color: #f7f7f2;
      font-variant-numeric: tabular-nums;
      text-align: center;
    }

    .wizwiki-ask-dojo-scoreboard-main span {
      grid-column: 1 / -1;
      color: #22d3ee;
      font-size: 10px;
      font-weight: 1000;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .wizwiki-ask-dojo-scoreboard-main strong {
      align-self: end;
      color: #7cff9b;
      font-size: 42px;
      line-height: 0.92;
      letter-spacing: 0;
    }

    .wizwiki-ask-dojo-scoreboard-main em {
      align-self: end;
      color: rgba(247, 247, 242, 0.58);
      font-size: 13px;
      font-style: normal;
      font-weight: 900;
      line-height: 1.15;
    }

    .wizwiki-ask-dojo-scoreboard-meta {
      display: grid;
      align-content: center;
      gap: 5px;
      min-width: 0;
    }

    .wizwiki-ask-dojo-scoreboard-meta span {
      display: grid;
      grid-template-columns: 64px minmax(0, 1fr);
      gap: 8px;
      min-width: 0;
      color: rgba(247, 247, 242, 0.78);
      font-size: 11px;
      line-height: 1.25;
      overflow-wrap: anywhere;
    }

    .wizwiki-ask-dojo-scoreboard-meta b {
      color: #ff8dae;
      font-size: 9px;
      font-weight: 1000;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-telemetry {
      display: grid;
      gap: 8px;
      margin-top: 10px;
      border-top: 1px dotted rgba(247, 247, 242, 0.22);
      padding-top: 10px;
      color: rgba(247, 247, 242, 0.72);
      font-size: 11px;
      line-height: 1.45;
    }

    .wizwiki-ask-autopilot-telemetry--compact {
      gap: 6px;
      margin-top: 8px;
      padding-top: 8px;
      font-size: 10px;
      line-height: 1.25;
    }

    .wizwiki-ask-autopilot-telemetry-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .wizwiki-ask-autopilot-telemetry-chips span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      min-height: 24px;
      border: 1px dotted rgba(34, 211, 238, 0.44);
      background: rgba(34, 211, 238, 0.08);
      padding: 4px 7px;
      color: #f7f7f2;
      overflow-wrap: anywhere;
    }

    .wizwiki-ask-autopilot-telemetry-chips b {
      flex: 0 0 auto;
      color: #22d3ee;
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-telemetry-chips em {
      font-style: normal;
      font-variant-numeric: tabular-nums;
    }

    .wizwiki-ask-autopilot-telemetry--compact .wizwiki-ask-autopilot-telemetry-chips {
      gap: 5px;
    }

    .wizwiki-ask-autopilot-telemetry--compact .wizwiki-ask-autopilot-telemetry-chips span {
      min-height: 21px;
      max-width: 100%;
      padding: 3px 6px;
    }

    .wizwiki-ask-autopilot-telemetry--compact .wizwiki-ask-autopilot-telemetry-chips b {
      font-size: 8px;
    }

    .wizwiki-ask-autopilot-telemetry--compact .wizwiki-ask-autopilot-telemetry-chips em {
      max-width: 340px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .wizwiki-ask-autopilot-telemetry-timeline {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(145px, 1fr));
      gap: 6px;
    }

    .wizwiki-ask-autopilot-telemetry-timeline span {
      display: grid;
      gap: 2px;
      border: 1px dotted rgba(124, 255, 155, 0.32);
      background: rgba(124, 255, 155, 0.055);
      padding: 6px 8px;
      min-width: 0;
    }

    .wizwiki-ask-autopilot-telemetry-timeline b {
      color: #7cff9b;
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-telemetry-timeline strong {
      color: #f7f7f2;
      font-size: 15px;
      font-variant-numeric: tabular-nums;
      line-height: 1.15;
    }

    .wizwiki-ask-autopilot-telemetry-timeline small {
      color: rgba(247, 247, 242, 0.52);
      font-size: 10px;
      line-height: 1.25;
    }

    .wizwiki-ask-autopilot-telemetry p,
    .wizwiki-ask-autopilot-telemetry ul {
      margin: 0;
    }

    .wizwiki-ask-autopilot-telemetry p {
      color: rgba(247, 247, 242, 0.82);
    }

    .wizwiki-ask-autopilot-telemetry ul {
      display: grid;
      gap: 5px;
      padding-left: 0;
      list-style: none;
    }

    .wizwiki-ask-autopilot-telemetry li {
      display: grid;
      grid-template-columns: 78px minmax(0, 1fr);
      gap: 8px;
      color: rgba(247, 247, 242, 0.64);
    }

    .wizwiki-ask-autopilot-telemetry li b {
      color: #ff8dae;
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-telemetry li span {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .wizwiki-ask-autopilot-alert {
      display: grid;
      gap: 10px;
      margin-top: 12px;
      border: 2px solid rgba(255, 45, 98, 0.72);
      background:
        linear-gradient(135deg, rgba(255, 45, 98, 0.14), rgba(0, 0, 0, 0.76)),
        rgba(0, 0, 0, 0.72);
      padding: 12px;
      color: #f7f7f2;
      animation: wizwikiAskAutopilotAlertFlash 1.1s ease-in-out infinite;
    }

    .wizwiki-ask-autopilot-alert-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }

    .wizwiki-ask-autopilot-alert-head strong {
      color: #ff8dae;
      font-size: 13px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-alert-head span {
      color: rgba(247, 247, 242, 0.62);
      font-size: 10px;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-alert p,
    .wizwiki-ask-autopilot-alert ul {
      margin: 0;
    }

    .wizwiki-ask-autopilot-alert > p {
      color: rgba(247, 247, 242, 0.86);
      line-height: 1.45;
    }

    .wizwiki-ask-autopilot-alert ul {
      display: grid;
      gap: 6px;
      padding-left: 0;
      list-style: none;
    }

    .wizwiki-ask-autopilot-alert li {
      display: grid;
      grid-template-columns: 96px minmax(0, 1fr);
      gap: 8px;
      color: rgba(247, 247, 242, 0.74);
      line-height: 1.45;
    }

    .wizwiki-ask-autopilot-alert li b {
      color: #ff8dae;
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .wizwiki-ask-autopilot-alert li span {
      min-width: 0;
      overflow-wrap: anywhere;
    }

    .autos-ask-autopilot-rag-trace {
      display: grid;
      gap: 7px;
      border-top: 1px dotted rgba(247, 247, 242, 0.2);
      padding-top: 8px;
    }

    .autos-ask-autopilot-rag-trace > strong {
      color: #7cff9b;
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .autos-ask-autopilot-rag-trace > div {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .autos-ask-autopilot-rag-trace > div span {
      display: inline-flex;
      align-items: center;
