<% content_for :title, "Report Maker" %>

<% sync_status = @ticket_sync_status || {} %>
<% contact_sync_active = sync_status[:contact_sync_active] %>
<% active_handoff = @queued_report_count.to_i.positive? %>

<section class="design-dark-panel border-2 border-dotted p-4 sm:p-5">
  <div class="grid gap-5 lg:grid-cols-[minmax(0,1.08fr)_minmax(22rem,0.92fr)] lg:items-start">
    <div>
      <p class="font-mono text-[10px] font-black uppercase tracking-[0.35em] text-pink-300">report maker // Thumper voice workspace</p>
      <h1 class="mt-2 font-mono text-3xl font-black tracking-[-0.06em] text-white sm:text-4xl">Report Maker</h1>
      <p class="mt-3 max-w-4xl font-mono text-xs leading-6 text-zinc-300 sm:text-sm">
        Choose a source lane, claim a card, then use RUN and COMM KIT to create Thumper-voice comm kits, client-facing market reports, Canva build kits, and follow-up packages. Owner Queue is the default source lane, while ALL, SAM, Facebook, Shopify, Haymarket, and Storm Watch stay available for broader report work.
      </p>

      <div class="mt-4 grid gap-3" data-controller="ticket-sync-status" data-ticket-sync-status-url-value="<%= sync_deal_queue_status_path(format: :json) %>" data-ticket-sync-status-interval-value="5000" data-ticket-sync-active="<%= contact_sync_active ? "true" : "false" %>">
        <div class="grid gap-3 xl:grid-cols-[minmax(0,1fr)_minmax(17rem,0.62fr)]">
          <div class="border border-dotted border-cyan-300/45 bg-cyan-950/10 p-3">
            <div class="flex flex-wrap items-end gap-2">
              <form action="<%= deal_queue_path %>" method="get" class="grid min-w-56 flex-1 gap-1">
                <label for="hero_lead_source" class="font-mono text-[9px] font-black uppercase tracking-[0.2em] text-cyan-100">Source lane</label>
                <select id="hero_lead_source" name="lead_source" class="border border-dotted border-cyan-300/80 bg-black px-3 py-3 font-mono text-xs font-black text-cyan-100" aria-label="Source lane">
                  <% @lead_source_options.each do |source| %>
                    <option value="<%= source[:value] %>" <%= "selected" if @active_lead_source == source[:value] %>><%= source[:label] %> (<%= number_with_delimiter(@lead_source_counts[source[:value]].to_i) %>)</option>
                  <% end %>
                </select>
                <button type="submit" class="design-soft-button border border-dotted border-cyan-300/60 bg-black px-3 py-2 font-mono text-[10px] font-black text-cyan-100 hover:bg-cyan-300 hover:text-black">OPEN LANE</button>
              </form>
              <% if @canva_connection&.connected? %>
                <span class="border border-dotted border-green-300 bg-green-950/30 px-4 py-3 font-mono text-[10px] font-black text-green-100">🎨 CANVA CONNECTED</span>
              <% else %>
                <%= link_to "🎨 CONNECT CANVA", connect_canva_path, class: "design-soft-button border border-dotted border-green-300/80 px-4 py-3 font-mono text-[10px] font-black text-green-100 #{'pointer-events-none opacity-50' unless @canva_configured}" %>
              <% end %>
              <%= button_to "📇 SYNC 90-DAY CONTACTS", sync_deal_queue_path(lead_source: @active_lead_source), method: :post, disabled: !@hubspot_configured || contact_sync_active, class: "design-soft-button border border-dotted border-cyan-300/80 bg-cyan-950/25 px-4 py-3 font-mono text-[10px] font-black text-cyan-100 disabled:cursor-not-allowed disabled:opacity-50 hover:bg-cyan-300 hover:text-black", data: { turbo_confirm: "Sync HubSpot contacts created in the last 90 days, refresh associations, and update Facebook/Shopify/Haymarket lead lanes?", ticket_sync_status_target: "button", hubspot_configured: @hubspot_configured ? "true" : "false" } %>
              <%= link_to "⛈️ WEATHER BRAIN", weather_path, class: "design-soft-button border border-dotted border-yellow-300/80 bg-black px-4 py-3 font-mono text-[10px] font-black text-yellow-100 hover:bg-yellow-300 hover:text-black" %>
            </div>
          </div>

          <div class="border border-dotted border-fuchsia-300/70 bg-fuchsia-950/20 p-3 shadow-lg shadow-fuchsia-500/10">
            <p class="font-mono text-[9px] font-black uppercase tracking-[0.22em] text-fuchsia-100">WIZWIKI COMMS</p>
            <div class="mt-2 grid grid-cols-2 gap-2">
              <div class="border border-dotted border-fuchsia-200/40 bg-black/35 p-2">
                <p class="font-mono text-[8px] uppercase tracking-[0.16em] text-fuchsia-100/75">claimed report cards</p>
                <strong class="block font-mono text-2xl leading-none text-white"><%= number_with_delimiter(@my_claimed_count.to_i) %></strong>
                <p class="mt-1 font-mono text-[8px] uppercase tracking-[0.1em] text-fuchsia-100/60">ready to load</p>
              </div>
              <div class="border border-dotted border-lime-200/40 bg-black/35 p-2">
                <p class="font-mono text-[8px] uppercase tracking-[0.16em] text-lime-100/75">loaded call blocks</p>
                <strong class="block font-mono text-2xl leading-none text-white"><%= number_with_delimiter(@comm_staged_count.to_i) %></strong>
                <p class="mt-1 font-mono text-[8px] uppercase tracking-[0.1em] text-lime-100/60">in WIZWIKI COMMS</p>
              </div>
            </div>
            <div class="mt-3 grid gap-2 sm:grid-cols-2">
              <%= link_to "OPEN COMMS", comms_command_path, class: "design-soft-button hero-phone-action border border-dotted border-lime-300/80 bg-lime-950/25 px-5 py-3 text-center font-mono text-[11px] font-black text-lime-100 hover:bg-lime-300 hover:text-black" %>
              <%= button_to "☎ LOAD MY COMMS", run_all_deal_comms_path, method: :post, disabled: @my_claimed_count.to_i.zero?, class: "w-full design-soft-button hero-phone-action border border-dotted border-fuchsia-300/80 bg-fuchsia-950/30 px-5 py-3 font-mono text-[11px] font-black text-fuchsia-100 disabled:cursor-not-allowed disabled:opacity-50 hover:bg-fuchsia-300 hover:text-black", data: { turbo_confirm: "Stage all lead cards claimed by you into WIZWIKI COMMS? This will not send SMS." } %>
            </div>
          </div>
        </div>
        <div data-ticket-sync-status-target="panel" class="max-w-xl border border-dotted <%= sync_status[:active] ? 'border-pink-300 bg-pink-950/25 text-pink-100' : sync_status[:state] == 'success' ? 'border-green-300/60 bg-green-950/20 text-green-100' : sync_status[:state] == 'failed' ? 'border-teal-300/70 bg-teal-950/25 text-teal-100' : 'border-white/25 bg-black/35 text-zinc-300' %> px-3 py-2 font-mono text-[10px] uppercase tracking-[0.16em]">
          <p class="font-black"><span data-ticket-sync-status-target="state"><%= sync_status[:state_label].to_s.upcase.presence || "SYNC IDLE" %></span> <span data-ticket-sync-status-target="duration" class="text-zinc-500"><%= sync_status[:duration_label].present? ? "duration #{sync_status[:duration_label]}" : "" %></span></p>
          <p data-ticket-sync-status-target="detail" class="mt-1 leading-4"><%= sync_status[:detail_label].presence || "No contact sync has been started yet." %></p>
          <p data-ticket-sync-status-target="lastSuccess" class="mt-1 leading-4 text-zinc-300"><%= sync_status[:last_success_label].presence || "No successful contact sync yet." %></p>
          <p data-ticket-sync-status-target="counts" class="mt-1 leading-4 text-zinc-400"><%= sync_status[:counts_label] %></p>
        </div>
      </div>

      <% unless @canva_configured %>
        <p class="mt-4 border border-dotted border-yellow-400 bg-yellow-950/30 px-4 py-3 font-mono text-xs text-yellow-100">
          Canva client ID/secret are not configured for this Rails process yet. Add both values, restart WIZWIKI, then connect Canva.
        </p>
      <% end %>
      <% unless @hubspot_configured %>
        <p class="mt-4 border border-dotted border-teal-500 bg-teal-950/40 px-4 py-3 font-mono text-xs text-teal-100">
          HUBSPOT_KEY is not configured for this Rails process. Add the key, restart WIZWIKI, then sync.
        </p>
      <% end %>
    </div>

    <div class="grid gap-3">
      <turbo-frame id="deal_queue_stats">
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-3">
          <% [
            ["filtered", @filtered_count, "of #{number_with_delimiter(@total_count)} synced", "border-white/30 text-white"],
            ["priority", @priority_count, "manual or HubSpot", "border-yellow-300/70 text-yellow-100"],
            ["unclaimed", @unclaimed_count, "open lane", "border-green-300/70 text-green-100"],
            ["claimed", @claimed_count, "owned cards", "border-cyan-300/70 text-cyan-100"],
            ["source pool", @recent_count, @active_lead_source_label, "border-orange-300/70 text-orange-100"],
            ["ready kits", @completed_report_count, "completed assets", "border-pink-300/70 text-pink-100"]
          ].each do |label, value, detail, classes| %>
            <div class="border border-dotted bg-black/35 p-3 <%= classes %>">
              <p class="font-mono text-[8px] uppercase tracking-[0.18em] opacity-75"><%= label %></p>
              <strong class="mt-1 block font-mono text-2xl leading-none"><%= number_with_delimiter(value.to_i) %></strong>
              <p class="mt-1 truncate font-mono text-[8px] uppercase tracking-[0.12em] opacity-70"><%= detail %></p>
            </div>
          <% end %>
        </div>
      </turbo-frame>

      <turbo-frame id="deal_queue_processing_bay">
        <div class="border border-dotted <%= active_handoff ? 'border-pink-300/80 bg-pink-950/25 text-pink-100' : 'border-white/25 bg-black/35 text-zinc-400' %> p-3">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="font-mono text-[9px] font-black uppercase tracking-[0.25em] text-pink-300">Thumper Build Bay</p>
              <p class="mt-1 font-mono text-[10px] uppercase tracking-[0.14em]"><%= active_handoff ? pluralize(@queued_report_count, 'active package') : 'Thumper idle // no active packages' %></p>
            </div>
            <span class="am-report-working-icon <%= 'am-report-working-icon--active' if active_handoff %> text-2xl">🧠⚡</span>
          </div>
          <div class="am-report-handoff-meter <%= 'am-report-handoff-meter--active' if active_handoff %> mt-3"><span style="width: <%= active_handoff ? 42 : 8 %>%"></span></div>
          <div id="processing-bay-live-feedback" hidden class="processing-bay-live-feedback mt-3 border border-dotted border-pink-300/70 bg-pink-950/25 px-3 py-2 font-mono text-[10px] font-black uppercase tracking-[0.18em] text-pink-100"></div>

          <% if @report_queue.any? %>
            <div class="mt-3 grid gap-2">
              <% @report_queue.each do |artifact| %>
                <% deal = artifact.crm_record %>
                <article id="deal-report-queue-item-<%= artifact.id %>" class="border border-dotted border-white/20 bg-black/45 p-2">
                  <div class="flex items-start justify-between gap-2">
                    <div class="min-w-0">
                      <p class="truncate text-xs font-black text-white"><%= deal ? deal_company_name(deal) : artifact.title %></p>
                      <p class="mt-1 font-mono text-[9px] uppercase tracking-[0.12em] text-zinc-500">artifact #<%= artifact.id %> // <%= artifact.status %></p>
                      <p class="mt-1 truncate text-[11px] text-zinc-300"><%= report_display_title(artifact) %></p>
                    </div>
                    <%= button_to "X", remove_deal_report_from_queue_path(artifact), method: :delete, form_class: "contents", class: "am-report-x-button shrink-0 border border-dotted border-teal-300/80 bg-black px-2 py-1 text-center font-mono text-[9px] font-black text-teal-100 hover:bg-teal-300 hover:text-black", title: "Remove from Processing Bay", data: { turbo_confirm: "Remove this AM report from the Processing Bay?" } %>
                  </div>
                </article>
              <% end %>
            </div>
          <% end %>
        </div>
      </turbo-frame>
    </div>
  </div>
</section>

<section class="design-dark-panel mt-4 border border-dotted p-4">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="font-mono text-[10px] font-black uppercase tracking-[0.35em] text-pink-300">source cards // <%= @active_lead_source_label %></p>
      <h2 class="mt-1 font-mono text-xl font-black text-white">Report + comm cards</h2>
      <p class="mt-2 max-w-3xl font-mono text-xs leading-5 text-zinc-400">Claimed-by-you cards pin to the top. Use RUN for client reports and COMM KIT for Thumper-voice SMS/email outreach. Owner Queue loads Sample Owner-owned HubSpot lead records first; ALL combines Sample Owner, SAM, Facebook, Shopify, Haymarket, and Storm Watch lanes.</p>
      <p class="mt-2 inline-flex border border-dotted border-green-300/50 bg-green-950/20 px-3 py-2 font-mono text-[10px] font-black uppercase tracking-[0.16em] text-green-100">showing <%= number_with_delimiter(@visible_count || @deals.size) %> of <%= number_with_delimiter(@filtered_count) %> filtered cards // <%= number_with_delimiter(@total_count) %> synced total</p>
    </div>
    <form action="<%= deal_queue_path %>" method="get" class="flex min-w-72 flex-1 flex-wrap justify-end gap-2" data-controller="instant-filter" data-instant-filter-delay-value="180" data-action="input->instant-filter#queue change->instant-filter#submit turbo:submit-end->instant-filter#refreshFrames" data-turbo-frame="deal_queue_results">
      <select name="lead_source" class="border border-dotted border-pink-300/80 bg-black px-3 py-2 font-mono text-xs font-black text-pink-100" aria-label="Source lane">
        <% @lead_source_options.each do |source| %>
          <option value="<%= source[:value] %>" <%= "selected" if @active_lead_source == source[:value] %>><%= source[:label] %> (<%= number_with_delimiter(@lead_source_counts[source[:value]].to_i) %>)</option>
        <% end %>
      </select>
      <input type="search" name="q" value="<%= params[:q] %>" placeholder="search cards, owners, companies" class="min-w-52 flex-1 border border-dotted border-white/35 bg-black px-3 py-2 font-mono text-xs text-white placeholder:text-zinc-600">
      <select name="priority_status" class="border border-dotted border-yellow-300/70 bg-black px-3 py-2 font-mono text-xs text-yellow-100" aria-label="Priority status">
        <option value="">all priority</option>
        <option value="priority" <%= "selected" if params[:priority_status] == "priority" %>>priority only</option>
        <option value="standard" <%= "selected" if params[:priority_status] == "standard" %>>standard only</option>
      </select>
      <select name="claim_status" class="border border-dotted border-white/35 bg-black px-3 py-2 font-mono text-xs text-white">
        <option value="">all claims</option>
        <option value="unclaimed" <%= "selected" if params[:claim_status] == "unclaimed" %>>unclaimed</option>
        <option value="claimed" <%= "selected" if params[:claim_status] == "claimed" %>>claimed</option>
      </select>
      <select name="claim_owner_id" class="border border-dotted border-white/35 bg-black px-3 py-2 font-mono text-xs text-white">
        <option value="">all owners</option>
        <% @claim_owners.each do |owner| %>
          <option value="<%= owner.id %>" <%= "selected" if params[:claim_owner_id].to_s == owner.id.to_s %>><%= owner.display_name %></option>
        <% end %>
      </select>
      <% if @ticket_pipeline_filters_enabled %>
        <select name="pipeline_id" class="border border-dotted border-white/35 bg-black px-3 py-2 font-mono text-xs text-white" aria-label="HubSpot ticket pipeline">
          <option value="all" <%= "selected" if @active_pipeline_id.blank? && @active_ticket_status_value.blank? %>>all pipelines</option>
          <% @ticket_pipeline_options.each do |pipeline| %>
            <option value="<%= pipeline[:id] %>" <%= "selected" if @active_pipeline_id.to_s == pipeline[:id].to_s && @active_ticket_status_value.blank? %>><%= pipeline[:label] %></option>
          <% end %>
        </select>
        <select name="ticket_status" class="border border-dotted border-white/35 bg-black px-3 py-2 font-mono text-xs text-white" aria-label="HubSpot Ticket status">
          <option value="" <%= "selected" if @active_ticket_status_value.blank? %>>all ticket statuses</option>
          <% @ticket_pipeline_options.each do |pipeline| %>
            <optgroup label="<%= pipeline[:label] %>">
              <% pipeline[:stages].each do |stage| %>
                <% status_value = "#{pipeline[:id]}:#{stage[:id]}" %>
                <option value="<%= status_value %>" <%= "selected" if @active_ticket_status_value == status_value %>><%= stage[:label] %></option>
              <% end %>
            </optgroup>
          <% end %>
        </select>
      <% else %>
        <span class="border border-dotted border-pink-300/40 bg-pink-950/20 px-3 py-2 font-mono text-[10px] font-black uppercase tracking-[0.14em] text-pink-100">
          <%= @active_lead_source_option[:short_label] %> source match
        </span>
      <% end %>
      <button type="submit" class="design-soft-button border border-dotted border-white/50 px-4 py-2 font-mono text-[10px] font-black text-white">FILTER</button>
    </form>
  </div>
  <p class="mt-3 border border-dotted border-white/20 bg-black/35 px-3 py-2 font-mono text-[10px] uppercase tracking-[0.18em] text-zinc-300">
    lead source // <span class="text-green-100"><%= @active_lead_source_label %></span>
    <% if @ticket_pipeline_filters_enabled %>
      // hs_pipeline_stage focus // <span class="text-green-100"><%= @active_ticket_status_label.presence || "#{@active_pipeline_label} // all statuses" %></span>
    <% else %>
      // <span class="text-green-100"><%= @active_lead_source_option[:description] %></span>
    <% end %>
  </p>

  <div class="mt-4 inline-flex items-center gap-3 border border-dotted border-green-300/60 bg-green-950/20 px-4 py-3 font-mono uppercase tracking-[0.18em] text-green-100">
    <span class="text-[10px] text-zinc-400">current filter</span>
    <strong class="text-2xl leading-none text-white"><%= number_with_delimiter(@filtered_count) %></strong>
    <span class="text-[10px]">report cards showing</span>
  </div>

  <turbo-frame id="deal_queue_results">
    <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-3">
      <% @deals.each do |deal| %>
        <% company_name = deal_company_name(deal) %>
        <% claimed_by_me = deal_claimed_by_current_user?(deal) %>
        <% priority_level = deal_priority_level(deal) %>
        <% priority_card_class = if priority_level == "urgent"
          "border-teal-300/90 bg-teal-950/25 shadow-lg shadow-teal-500/15 ring-1 ring-teal-300/40"
        elsif priority_level == "priority"
          "border-yellow-300/80 bg-yellow-950/20 shadow-lg shadow-yellow-400/10 ring-1 ring-yellow-300/30"
        elsif claimed_by_me
          "border-cyan-200/80 bg-cyan-950/35 shadow-lg shadow-cyan-400/10 ring-1 ring-cyan-200/30"
        else
          "border-white/25 bg-black/40"
        end %>
        <% media_attachments = deal.deal_media.attachments.to_a %>
        <% artifacts = deal.crm_record_artifacts.select { |artifact| artifact.artifact_type == "market_report" }.sort_by { |artifact| artifact.created_at || Time.zone.at(0) }.reverse %>
        <% comm_stages = claimed_by_me ? deal.crm_record_artifacts.select { |artifact| artifact.artifact_type == "comm_staging" && artifact.status.to_s.in?(%w[staged aircall_ready aircall_sent]) }.sort_by { |artifact| artifact.updated_at || artifact.created_at || Time.zone.at(0) }.reverse : [] %>
        <% latest_comm_stage = comm_stages.first %>
        <% completed_report_count = deal_completed_report_count(deal) %>
        <% latest_ready_report = artifacts.find { |artifact| canva_kit_downloadable?(artifact) } %>
        <% client_report_count = artifacts.count { |artifact| (artifact.metadata.to_h["report_audience"].presence || "client").to_s == "client" } %>
        <% am_report_count = artifacts.count { |artifact| artifact.metadata.to_h["report_audience"].to_s == "am" } %>
        <% copy_maker_report_count = artifacts.count { |artifact| artifact.metadata.to_h["report_audience"].to_s == "copy_maker" } %>
        <% active_client_report = artifacts.find { |artifact| artifact.status.in?(%w[queued generating report_ready]) && (artifact.metadata.to_h["report_audience"].presence || "client").to_s == "client" } %>
        <% active_am_report = artifacts.find { |artifact| artifact.status.in?(%w[queued generating report_ready]) && artifact.metadata.to_h["report_audience"].to_s == "am" } %>
        <% active_copy_maker_report = artifacts.find { |artifact| artifact.status.in?(%w[queued generating report_ready]) && artifact.metadata.to_h["report_audience"].to_s == "copy_maker" } %>
        <% active_reports = [active_client_report, active_am_report, active_copy_maker_report].compact %>
        <% deal_overview_rows = [
          ["Company", company_name],
          ["Deal", deal.name],
          ["Stage", deal.stage],
          ["Status", deal.status],
          ["Amount", deal.amount.present? ? number_to_currency(deal.amount) : nil],
          ["Close date", deal.close_date],
          ["Owner", deal_claim_label(deal)],
          ["Priority", "#{deal_priority_label(deal)} // #{deal_priority_source(deal)}"],
          ["Source", deal.source],
          ["HubSpot ID", deal.source_uid],
          ["Created", deal.created_at&.strftime("%b %-d, %Y %l:%M %p")],
          ["Updated", deal.updated_at&.strftime("%b %-d, %Y %l:%M %p")]
        ] %>
        <% raw_hubspot_properties = (deal.properties.to_h.dig("hubspot", "properties") || {}).to_h.sort_by { |key, _value| key.to_s } %>
        <% weather_signals = weather_lead_signals_for(deal) %>

        <article id="deal-card-<%= deal.id %>" data-deal-card class="design-hover-tile relative grid min-h-52 content-between gap-3 border border-dotted p-3 <%= priority_card_class %>">
          <details class="deal-info-details relative">
            <summary class="deal-info-summary list-none">
              <div class="deal-info-card">
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <h3 class="text-base font-black leading-tight text-white"><%= company_name %></h3>
                    <% if deal_priority?(deal) %>
                      <p class="mt-1 inline-flex border border-dotted px-2 py-1 font-mono text-[9px] font-black uppercase tracking-[0.18em] <%= deal_priority_badge_class(deal) %>">⚡ <%= deal_priority_label(deal) %> // <%= deal_priority_source(deal) %></p>
                    <% end %>
                    <% if claimed_by_me %>
                      <p class="deal-card-claim-badge mt-1 inline-flex border border-dotted border-cyan-200/70 bg-cyan-200/10 px-2 py-1 font-mono text-[9px] font-black uppercase tracking-[0.18em] text-cyan-100">claimed by you // pinned</p>
                    <% elsif deal_claimed?(deal) %>
                      <p class="deal-card-claim-badge mt-1 inline-flex border border-dotted border-white/25 bg-white/5 px-2 py-1 font-mono text-[9px] uppercase tracking-[0.18em] text-zinc-300">claimed by <%= deal_claim_label(deal) %></p>
                    <% end %>
                    <% if deal.name != company_name %>
                      <p class="mt-1 line-clamp-1 text-xs text-zinc-500"><%= deal.name %></p>
                    <% end %>
                  </div>
                  <div class="grid shrink-0 gap-1 text-right">
                    <span class="deal-card-count-badge border border-dotted border-white/30 px-2 py-1 font-mono text-[9px] uppercase tracking-[0.14em] text-zinc-300"><%= completed_report_count %> rpt // <%= media_attachments.size %> media</span>
                    <% if latest_ready_report.present? %>
                      <%= link_to "READY KIT ##{latest_ready_report.id}", canva_kit_url(latest_ready_report), data: { turbo: false }, class: "inline-block border border-dotted border-green-300 bg-green-950/30 px-2 py-1 font-mono text-[9px] font-black uppercase tracking-[0.14em] text-green-100 hover:bg-green-300 hover:text-black" %>
                    <% end %>
                  </div>
                </div>
                <% if weather_signals.any? %>
                  <div class="mt-3 border border-dotted border-yellow-300/70 bg-yellow-950/20 p-2 font-mono text-[9px] uppercase tracking-[0.13em] text-yellow-100">
                    <p class="font-black tracking-[0.18em]">⛈️ storm watch match</p>
                    <div class="mt-2 grid gap-1">
                      <% weather_signals.each do |signal| %>
