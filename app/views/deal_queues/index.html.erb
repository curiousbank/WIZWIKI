      <% selected_address = comm_stage_selected_address(comm_stage).to_h %>
      <div class="mt-3 grid gap-2 lg:grid-cols-2">
        <div class="border border-dotted border-white/20 bg-black/45 p-2">
          <p class="font-mono text-[9px] font-black uppercase tracking-[0.15em] text-lime-100">Thumper favorite text</p>
          <p class="mt-1 text-xs leading-5 text-white"><%= selected_sms["body"].presence || "No SMS selected yet." %></p>
          <p class="mt-1 font-mono text-[9px] uppercase tracking-[0.12em] text-zinc-500"><%= selected_sms["tone"] %> // <%= selected_sms["urgency"] %></p>
        </div>
        <div class="border border-dotted border-white/20 bg-black/45 p-2">
          <p class="font-mono text-[9px] font-black uppercase tracking-[0.15em] text-cyan-100">Thumper favorite email</p>
          <p class="mt-1 font-mono text-[10px] font-black text-white">Subject: <%= selected_email["subject"].presence || "pending" %></p>
          <p class="mt-1 text-xs leading-5 text-zinc-200"><%= selected_email["body"].presence || "No email selected yet." %></p>
        </div>
      </div>
      <div class="mt-3 border border-dotted border-amber-200/35 bg-black/35 p-2">
        <p class="font-mono text-[9px] font-black uppercase tracking-[0.16em] text-amber-100">Recipient intelligence</p>
        <p class="mt-1 text-xs leading-5 text-zinc-300"><%= comm_stage.metadata.to_h.dig("contact_intelligence", "ranking_note").presence || "Ranked from associated CRM records, available phone/email fields, and recent communications." %></p>
        <div class="mt-2 grid gap-2 lg:grid-cols-4">
          <div class="border border-dotted border-white/15 bg-white/5 p-2">
            <p class="font-mono text-[9px] uppercase tracking-[0.14em] text-amber-100">Selected contact</p>
            <p class="mt-1 text-xs font-black text-white"><%= selected_contact["name"].presence || "No contact selected" %></p>
            <p class="mt-1 text-[11px] leading-4 text-zinc-400"><%= [selected_contact["title"], selected_contact["company"], selected_contact["association_type"]].compact_blank.join(" // ") %></p>
          </div>
          <div class="border border-dotted border-white/15 bg-white/5 p-2">
            <p class="font-mono text-[9px] uppercase tracking-[0.14em] text-lime-100">Selected phone</p>
            <p class="mt-1 text-xs font-black text-white"><%= selected_phone["value"].presence || "No phone selected" %></p>
            <p class="mt-1 text-[11px] leading-4 text-zinc-400"><%= selected_phone["name"] %></p>
          </div>
          <div class="border border-dotted border-white/15 bg-white/5 p-2">
            <p class="font-mono text-[9px] uppercase tracking-[0.14em] text-cyan-100">Selected email</p>
            <p class="mt-1 break-all text-xs font-black text-white"><%= selected_recipient_email["value"].presence || "No email selected" %></p>
            <p class="mt-1 text-[11px] leading-4 text-zinc-400"><%= selected_recipient_email["name"] %></p>
          </div>
          <div class="border border-dotted border-white/15 bg-white/5 p-2">
            <p class="font-mono text-[9px] uppercase tracking-[0.14em] text-pink-100">Selected address</p>
            <p class="mt-1 text-xs font-black leading-5 text-white"><%= selected_address["value"].presence || "No address selected" %></p>
            <p class="mt-1 text-[11px] leading-4 text-zinc-400"><%= selected_address["name"] %></p>
          </div>
        </div>
      </div>

      <% comms_sender_name = comm_stage.metadata.to_h.dig("sender_profile", "name").presence || comm_stage.metadata.to_h["sender_name"].presence || current_user&.display_name.to_s.presence || "WIZWIKI Marketing" %>
      <% comms_sender_name = comms_sender_name.to_s.squish.first(80) %>
      <% comms_sender_phone = comm_stage.metadata.to_h.dig("sender_profile", "phone").presence || comm_stage.metadata.to_h["sender_phone"].presence || current_user&.display_phone_number.to_s.presence %>
      <% sender_placeholder_pattern = /\[(?:your name|sender name|name)\]/i %>
      <% sender_phone_placeholder_pattern = /\[(?:your phone|sender phone|phone number|callback number)\]/i %>
      <% render_sender_copy = ->(value) { value.to_s.gsub(sender_placeholder_pattern, comms_sender_name).gsub(sender_phone_placeholder_pattern, comms_sender_phone.presence || "reply here") } %>
      <% composed_sms_body = render_sender_copy.call(comm_stage.metadata.to_h["composed_sms_body"].presence || selected_sms["body"]) %>
      <% composed_email_subject = render_sender_copy.call(comm_stage.metadata.to_h["composed_email_subject"].presence || selected_email["subject"]) %>
      <% composed_email_body = render_sender_copy.call(comm_stage.metadata.to_h["composed_email_body"].presence || selected_email["body"]) %>
      <% comms_composition_edited = ActiveModel::Type::Boolean.new.cast(comm_stage.metadata.to_h["composition_edited"]) %>
	      <details id="comms-lab-<%= comm_stage.id %>" class="relative mt-3 comms-lab-details" data-controller="comms-lab">
	        <summary class="comms-phone-action inline-grid cursor-pointer place-items-center border border-dotted border-lime-300 bg-lime-950/35 px-5 py-3 font-mono text-[12px] font-black uppercase tracking-[0.14em] text-lime-100 shadow-sm shadow-lime-300/25 hover:bg-lime-300 hover:text-black">
	          ☎ OPEN COMMS LAB
	        </summary>
        <div class="comms-lab-backdrop"></div>
        <div class="deal-flyout deal-flyout--report comms-lab-overlay" role="dialog" aria-modal="true" aria-label="COMMS LAB">
          <%= form_with url: run_deal_comms_path(comm_stage), method: :post, class: "comms-lab-form", data: { turbo_confirm: "Save this contact, text, and email for the Run All Calls batch? This will not send messages yet." } do %>
            <div class="comms-lab-header">
              <div>
                <p class="comms-lab-kicker">Thumper // COMMS LAB</p>
                <h3 class="comms-lab-title"><%= deal_company_name(artifact.crm_record) %></h3>
                <p class="comms-lab-subtitle">Pick the recipient, compose the text, compose the email, then save the work for the calls batch.</p>
              </div>
              <div class="comms-lab-sender">
                <span>Sender profile</span>
                <b><%= comms_sender_name %></b>
                <small><%= comms_sender_phone.presence || "phone not set" %> // <%= link_to "edit", edit_profile_path, class: "text-cyan-100 underline decoration-dotted underline-offset-4" %></small>
                <%= hidden_field_tag :sender_name_override, comms_sender_name, data: { comms_lab_target: "senderName" } %>
                <%= hidden_field_tag :sender_phone, comms_sender_phone, data: { comms_lab_target: "senderPhone" } %>
              </div>
              <div class="comms-lab-status">
                <span><%= comm_stage.metadata.to_h["comm_kit_direction_label"].presence || "WIZWIKI OUT" %></span>
                <span><%= comm_stage.status.to_s.humanize %></span>
              </div>
              <button type="button" class="comms-lab-close" data-action="comms-lab#close">CLOSE</button>
            </div>

            <div class="comms-lab-body">
              <section class="comms-lab-pane comms-lab-pane--contacts">
                <div class="comms-lab-pane-head">
                  <p>Recipient Router</p>
                  <span>ranked from CRM + recent comms</span>
                </div>
                <div class="comms-lab-route">
                  <div>
                    <span>CONTACT</span>
                    <b><%= selected_contact["name"].presence || "Choose contact" %></b>
                  </div>
                  <div>
                    <span>TEXT TO</span>
                    <b><%= selected_phone["value"].presence || "Choose phone" %></b>
                  </div>
                  <div>
                    <span>EMAIL TO</span>
                    <b><%= selected_recipient_email["value"].presence || "Choose email" %></b>
                  </div>
                  <div>
                    <span>ADDRESS</span>
                    <b><%= selected_address["value"].presence || "Review address" %></b>
                  </div>
                </div>

                <div class="comms-lab-choice-list">
                  <p class="comms-lab-choice-title">Contact name</p>
                  <% if comm_stage_contact_options(comm_stage).present? %>
                    <% comm_stage_contact_options(comm_stage).each do |option| %>
                      <% option = option.to_h %>
                      <label class="comms-lab-choice">
                        <%= radio_button_tag :selected_contact_id, option["id"], option["id"].to_s == selected_contact["id"].to_s, class: "accent-amber-300" %>
                        <span><b>#<%= option["rank"] %> <%= option["name"] %></b><em><%= [option["title"], option["record_type"], option["association_type"]].compact_blank.join(" // ") %></em><small><%= option["reason"] %></small></span>
                      </label>
                    <% end %>
                  <% else %>
                    <p class="comms-lab-empty">No associated contact candidates found.</p>
                  <% end %>
                </div>

                <div class="comms-lab-choice-list">
                  <p class="comms-lab-choice-title">Text number</p>
                  <% if comm_stage_phone_options(comm_stage).present? %>
                    <% comm_stage_phone_options(comm_stage).each do |option| %>
                      <% option = option.to_h %>
                      <label class="comms-lab-choice">
                        <%= radio_button_tag :selected_phone_id, option["id"], option["id"].to_s == selected_phone["id"].to_s, class: "accent-lime-300" %>
                        <span><b><%= option["name"] %></b><em><%= option["value"] %></em><small><%= option["reason"] %></small></span>
                      </label>
                    <% end %>
                  <% else %>
                    <p class="comms-lab-empty">No phone found in associated CRM records.</p>
                  <% end %>
                </div>

                <div class="comms-lab-choice-list">
                  <p class="comms-lab-choice-title">Email address</p>
                  <% if comm_stage_recipient_email_options(comm_stage).present? %>
                    <% comm_stage_recipient_email_options(comm_stage).each do |option| %>
                      <% option = option.to_h %>
                      <label class="comms-lab-choice">
                        <%= radio_button_tag :selected_recipient_email_id, option["id"], option["id"].to_s == selected_recipient_email["id"].to_s, class: "accent-cyan-300" %>
                        <span><b><%= option["name"] %></b><em class="break-all"><%= option["value"] %></em><small><%= option["reason"] %></small></span>
                      </label>
                    <% end %>
                  <% else %>
                    <p class="comms-lab-empty">No email found in associated CRM records.</p>
                  <% end %>
                </div>

                <div class="comms-lab-choice-list">
                  <p class="comms-lab-choice-title">Associated address</p>
                  <% if comm_stage_address_options(comm_stage).present? %>
                    <% comm_stage_address_options(comm_stage).each do |option| %>
                      <% option = option.to_h %>
                      <label class="comms-lab-choice">
                        <%= radio_button_tag :selected_address_id, option["id"], option["id"].to_s == selected_address["id"].to_s, class: "accent-pink-300" %>
                        <span><b><%= option["name"] %></b><em><%= option["value"] %></em><small><%= option["reason"] %></small></span>
                      </label>
                    <% end %>
                  <% else %>
                    <p class="comms-lab-empty">No address found in associated CRM records.</p>
                  <% end %>
                </div>
              </section>

              <section class="comms-lab-pane comms-lab-pane--sms">
                <div class="comms-lab-pane-head">
                  <p>Text Builder</p>
                  <span>choose one, then edit live</span>
                </div>
                <div class="comms-lab-copy-options">
                  <% comm_stage_sms_options(comm_stage).each do |option| %>
                    <% option = option.to_h %>
                    <label class="comms-lab-copy-option">
                      <%= radio_button_tag :selected_sms_id, option["id"], option["id"].to_s == selected_sms["id"].to_s, class: "accent-fuchsia-300", data: { action: "change->comms-lab#selectSms", comms_lab_body: option["body"].to_s } %>
                      <span><b><%= option["label"].presence || option["id"] %></b><em><%= option["tone"] %> // <%= option["urgency"] %></em><small><%= render_sender_copy.call(option["body"]) %></small></span>
                    </label>
                  <% end %>
                </div>
                <label class="comms-lab-editor">
                  <span>Final text body</span>
                  <%= text_area_tag :sms_body_override, composed_sms_body, rows: 9, maxlength: 700, data: { comms_lab_target: "smsBody", comms_lab_template: comms_composition_edited ? composed_sms_body : selected_sms["body"].to_s } %>
                </label>
              </section>

              <section class="comms-lab-pane comms-lab-pane--email">
                <div class="comms-lab-pane-head">
                  <p>Email Builder</p>
                  <span>subject + body are editable</span>
                </div>
                <div class="comms-lab-copy-options">
                  <% comm_stage_email_options(comm_stage).each do |option| %>
                    <% option = option.to_h %>
                    <label class="comms-lab-copy-option">
                      <%= radio_button_tag :selected_email_id, option["id"], option["id"].to_s == selected_email["id"].to_s, class: "accent-cyan-300", data: { action: "change->comms-lab#selectEmail", comms_lab_subject: option["subject"].to_s, comms_lab_body: option["body"].to_s } %>
                      <span><b><%= option["label"].presence || option["id"] %></b><em>Subject: <%= render_sender_copy.call(option["subject"]) %></em><small><%= render_sender_copy.call(option["body"]) %></small></span>
                    </label>
                  <% end %>
                </div>
                <label class="comms-lab-editor comms-lab-editor--subject">
                  <span>Final email subject</span>
                  <%= text_field_tag :email_subject_override, composed_email_subject, maxlength: 160, data: { comms_lab_target: "emailSubject", comms_lab_template: comms_composition_edited ? composed_email_subject : selected_email["subject"].to_s } %>
                </label>
                <label class="comms-lab-editor">
                  <span>Final email body</span>
                  <%= text_area_tag :email_body_override, composed_email_body, rows: 11, maxlength: 3_000, data: { comms_lab_target: "emailBody", comms_lab_template: comms_composition_edited ? composed_email_body : selected_email["body"].to_s } %>
                </label>
              </section>
            </div>

            <div class="comms-lab-footer">
              <% comm_kit_source_model = comm_stage.metadata.to_h["comm_kit_source_model"].presence %>
              <p>Source // <%= comm_stage.metadata.to_h["comm_kit_source"].presence || "unknown" %><%= comm_kit_source_model ? " // #{comm_kit_source_model}" : "" %></p>
              <p>Selector // <%= comm_stage.metadata.to_h["selector_provider"] %> <%= comm_stage.metadata.to_h["selector_model"] %> // <%= comm_stage.metadata.to_h["selection_reason"] %></p>
              <%= submit_tag comm_stage_aircall_ready?(comm_stage) ? "UPDATE SAVED WORK" : "SAVE WORK", class: "comms-lab-submit" %>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
<% end %>
<% if canva_output_downloadable?(artifact) %>
  <p class="mt-2 font-mono text-[10px] text-cyan-200">Canva output package ready. PDF, DOCX, kit, design links, and exports are bundled.</p>
<% elsif canva_kit_downloadable?(artifact) %>
  <% canva_status = canva_state["status"].to_s %>
  <% if canva_status == "failed" %>
    <div class="mt-2 border border-dotted border-teal-300/70 bg-teal-950/30 p-2">
      <p class="font-mono text-[10px] font-black uppercase tracking-[0.16em] text-teal-100">Canva build stopped</p>
      <p class="mt-1 text-xs leading-5 text-teal-100"><%= canva_state["message"].presence || "Canva returned an error before the output package was created." %></p>
      <p class="mt-1 font-mono text-[10px] text-zinc-300">The DOCX and Canva Kit are safe. Press <span class="text-pink-100">BUILD CANVA</span> again after the issue is fixed.</p>
    </div>
  <% elsif canva_status.present? && canva_status != "ready" %>
    <div class="mt-2 border border-dotted border-cyan-300/50 bg-cyan-950/20 p-2">
      <p class="font-mono text-[10px] font-black uppercase tracking-[0.16em] text-cyan-100"><%= canva_status_label(artifact) %></p>
      <p class="mt-1 text-xs leading-5 text-zinc-300"><%= canva_state["message"].presence || "Canva build is in progress or waiting on the next step." %></p>
    </div>
  <% else %>
    <div class="mt-2 border border-dotted border-pink-300/40 bg-pink-950/20 p-2">
      <p class="font-mono text-[10px] font-black uppercase tracking-[0.16em] text-pink-100">Ready for approval</p>
      <p class="mt-1 text-xs leading-5 text-zinc-300">Review the DOCX and Canva Kit. Press <span class="font-mono text-pink-100">BUILD CANVA</span> to create the Canva output package.</p>
      <% unless @canva_template_configured %>
        <p class="mt-1 font-mono text-[10px] text-yellow-100">No brand template yet. BUILD CANVA will import Alice's DOCX into Canva, then export and package the result.</p>
      <% end %>
    </div>
  <% end %>
<% elsif canva_state.present? %>
  <p class="mt-2 font-mono text-[10px] text-yellow-100"><%= canva_status_label(artifact) %></p>
<% elsif storage_key.present? %>
  <p class="mt-2 break-all font-mono text-[10px] text-zinc-400">DOCX ready. Waiting on Canva Build Kit zip.</p>
<% else %>
  <p class="mt-2 font-mono text-[10px] text-zinc-500">Download pending.</p>
<% end %>
                        </div>
                      <% end %>
                    </div>
                  <% else %>
                    <p class="mt-3 border border-dotted border-white/20 p-2 font-mono text-[10px] text-zinc-500">No report kits created yet.</p>
                  <% end %>
                </div>
              </details>
            </div>
            <% if watch_artifact.present? %>
              <div class="h-24 overflow-y-auto border border-dotted border-lime-300/35 bg-black/75 px-2 py-2 font-mono text-[8px] leading-3 text-lime-100 shadow-inner shadow-lime-950/60" aria-label="Report processing watch output">
                <div class="mb-1 flex items-center justify-between gap-2 border-b border-dotted border-lime-300/20 pb-1 text-[7px] font-black uppercase tracking-[0.18em] text-lime-300/75">
                  <span>AUTOS WATCH // DEAL <%= deal.id %></span>
                  <span><%= watch_artifact.updated_at.strftime("%H:%M:%S") %></span>
                </div>
                <% report_watch_lines(watch_artifact).each do |line| %>
                  <p class="break-words"><%= line %></p>
                <% end %>
              </div>
            <% end %>
          </div>
        </article>
      <% end %>

      <% if @deals.blank? %>
        <div class="col-span-full border border-dotted border-white/30 bg-black/35 p-6 text-zinc-300">
          <p class="font-mono text-sm font-black uppercase tracking-[0.16em] text-white">No <%= @active_lead_source_label.downcase %> leads match this view yet.</p>
          <% if @active_lead_source == "sam_tickets" %>
            <p class="mt-2 text-sm text-zinc-400">SAM ticket cards appear from the existing ticket-backed lane. Use the 90-day contact sync for contact-backed sources.</p>
          <% else %>
            <p class="mt-2 text-sm text-zinc-400">Run <%= @active_lead_source_label %> contact sync to search HubSpot contacts created in the last 90 days and populate this lane.</p>
          <% end %>
        </div>
      <% end %>
    </div>
  </turbo-frame>
</section>
