<% content_for :title, "Update Password" %>

<section class="mx-auto max-w-3xl border-2 border-dotted border-teal-600 bg-black p-6 shadow-2xl shadow-teal-950/50 sm:p-8">
  <p class="font-mono text-xs font-bold tracking-[0.45em] text-teal-500">account recovery // CAMPAIGN CRM</p>
  <h1 class="mt-3 font-mono text-4xl font-black tracking-[-0.06em] text-white">Update your password.</h1>

  <%= form_with url: password_path(params[:token]), method: :put, class: "mt-8 grid gap-5" do |form| %>
    <div>
      <%= form.label :password, "New password", class: "block font-mono text-xs font-bold uppercase tracking-[0.2em] text-teal-400" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Enter new password", maxlength: 72, class: "mt-2 w-full border border-dotted border-white/40 bg-[#090909] px-4 py-4 text-white" %>
    </div>

    <div>
      <%= form.label :password_confirmation, "Confirm password", class: "block font-mono text-xs font-bold uppercase tracking-[0.2em] text-teal-400" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Repeat new password", maxlength: 72, class: "mt-2 w-full border border-dotted border-white/40 bg-[#090909] px-4 py-4 text-white" %>
    </div>

    <%= form.submit "Save password", class: "w-full cursor-pointer border border-dotted border-white/50 bg-teal-700 px-6 py-4 font-mono text-[11px] font-black uppercase tracking-[0.18em] text-white hover:bg-white hover:text-black sm:w-auto" %>
  <% end %>
</section>
