                 data-follow-up-timer-due-at="<%= call_status[:due_at] %>"
                 data-follow-up-timer-prefix="<%= call_status[:timer_state].to_s == 'capped' ? 'CAP RESETS' : (call_status[:timer_state].to_s == 'outside_window' ? 'WINDOW IN' : 'NEXT IN') %>"
                 data-follow-up-timer-due-label="<%= call_status[:timer_state].to_s == 'capped' ? 'DAILY CAP RESET' : (call_status[:timer_state].to_s == 'outside_window' ? 'WINDOW OPEN' : 'STALE NOW') %>">
              <% if card_status_label.present? %>
                <b><%= card_status_label %></b>
              <% end %>
              <span><%= sms_callblock ? sms_callblock_reason.to_s.truncate(90) : call_status[:last_label] %></span>
              <span><em data-follow-up-timer-label><%= sms_callblock ? "HUMAN CHECK" : call_status[:next_label] %></em></span>
            </div>
          </div>

          <div class="comms-command-contact-snapshot <%= 'comms-command-contact-snapshot--empty' unless contact_snapshot_active %>">
