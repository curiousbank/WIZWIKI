                  <div class="comms-command-runall-actions comms-command-batch-stack">
                    <%= form_with url: run_all_comms_autopilot_path, method: :post, class: "comms-command-runall-form comms-command-batch-form", data: { comms_confirm_message: run_all_confirm, turbo_confirm: run_all_confirm }, onsubmit: comms_confirm_onsubmit_js do %>
                      <%= hidden_field_tag :q, @comms_query.presence %>
