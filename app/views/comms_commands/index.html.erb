      </summary>
      <div class="comms-command-mini-popover comms-command-mini-popover--media">
        <div class="comms-command-windowbar">
          <span></span><span></span><span></span>
          <b>MEDIA // <%= stage_company_name(stage) %></b>
          <button type="button" class="comms-command-mini-close" data-close-deal-flyout>X</button>
        </div>
        <p class="comms-command-mini-copy">Upload logos, photos, PDFs, notes, or campaign assets before running Thumper.</p>
        <% if record_claimed_by_me %>
          <form action="<%= upload_deal_media_path(comms_record) %>" method="post" enctype="multipart/form-data" class="comms-command-media-upload-form" data-turbo="false">
            <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>" autocomplete="off">
            <input type="file" name="deal_media[files][]" multiple accept="image/*,application/pdf,text/plain,.txt,.csv,.doc,.docx,.ppt,.pptx" class="comms-command-media-input">
            <button type="submit" class="comms-command-media-upload-button">UPLOAD MEDIA</button>
          </form>
        <% else %>
          <p class="comms-command-mini-warning">Claim this lead before uploading media.</p>
        <% end %>
        <div class="comms-command-media-list">
          <% if media_attachments.any? %>
            <% media_attachments.each do |attachment| %>
              <div class="comms-command-media-item">
                <% if attachment.blob.content_type.to_s.start_with?("image/") %>
                  <%= image_tag url_for(attachment), alt: attachment.filename.to_s, loading: "lazy", class: "comms-command-media-thumb" %>
                <% end %>
