            <details class="comms-command-email-followup" aria-label="SMS and email follow-up scheduler settings">
              <summary>
                <b>Scheduler</b>
                <span><%= email_follow_up_enabled ? "#{comms_email_follow_up_preset_label(email_follow_up_preset)} // AUTO ONLY" : "OFF" %></span>
              </summary>
              <div class="comms-command-email-followup-backdrop" onclick="this.closest('details').open=false" aria-hidden="true"></div>
              <section class="comms-command-email-followup-panel" role="dialog" aria-modal="true" aria-label="SMS and email follow-up scheduler settings" data-email-followup-panel data-email-followup-presets="<%= email_follow_up_preset_plans.to_json %>">
                <header class="comms-command-email-followup-head">
                  <div>
                    <p class="comms-command-kicker">sms + email // schedule</p>
                    <h3>Scheduler</h3>
                    <small>Only blocks with autopilot already on can send from this schedule.</small>
                  </div>
                </header>
                <%= form_with url: update_comms_follow_up_settings_path, method: :patch, class: "comms-command-email-followup-form" do %>
                  <%= hidden_field_tag "follow_up[email][enabled]", email_follow_up_enabled ? "1" : "0", data: { email_followup_enabled: "true" } %>
                  <%= hidden_field_tag "follow_up[email][schedule_mode]", email_follow_up_mode, data: { email_followup_mode: "true" } %>
                  <%= hidden_field_tag "follow_up[email][cadence]", email_follow_up_cadence, data: { email_followup_cadence: "true" } %>
                  <section class="comms-command-email-followup-section">
                    <div class="comms-command-email-followup-section-head">
                      <b>Scheduler</b>
                      <span data-email-followup-frequency-badge><%= email_follow_up_enabled ? (email_follow_up_cadence == "monthly" ? "30 DAY // SMS OFF WEEKENDS" : "1/DAY // SMS OFF WEEKENDS") : "OFF" %></span>
                    </div>
                    <div class="comms-command-email-followup-grid">
                      <label class="comms-command-email-followup-wide comms-command-email-followup-preset-field">
                        <%= select_tag "follow_up[email][preset]", options_for_select(comms_email_follow_up_preset_options, email_follow_up_preset_choice), class: "comms-command-launcher-input", data: { email_followup_preset: "true" }, onchange: "window.wizwikiEmailFollowUpPresetFill&&window.wizwikiEmailFollowUpPresetFill(this)", oninput: "window.wizwikiEmailFollowUpPresetFill&&window.wizwikiEmailFollowUpPresetFill(this)" %>
                        <span>Preset</span>
                      </label>
                    </div>
                    <div class="comms-command-email-monthly" data-email-followup-monthly-only data-email-followup-monthly-active="<%= email_follow_up_preset_choice == "monthly" ? "true" : "false" %>" <%= "hidden" unless email_follow_up_preset_choice == "monthly" %>>
                      <div class="comms-command-email-monthly-head">
                        <b>Next 8 weeks</b>
                        <span>Checked weeks can send; unchecked weeks pause SMS and email</span>
                      </div>
                      <div class="comms-command-email-monthly-grid">
                        <% email_follow_up_week_options.each do |week| %>
                          <label>
                            <%= check_box_tag "follow_up[email][selected_weeks][]", week[:key], email_follow_up_selected_weeks.include?(week[:key]), data: { email_followup_week: week[:key] } %>
                            <span>
                              <b>Week <%= week[:offset] %> // <%= week[:month] %></b>
                              <em><%= week[:range] %></em>
                            </span>
                          </label>
                        <% end %>
                      </div>
                    </div>
                  </section>
                  <section class="comms-command-email-followup-section">
                    <div class="comms-command-email-followup-section-head">
                      <b>Weekday Plan</b>
                      <span data-email-followup-plan-badge><%= email_follow_up_mode == "custom" ? "CUSTOM" : (email_follow_up_preset_choice == "monthly" ? "MONTHLY" : "PRESET") %> // SMS OFF SAT/SUN</span>
                    </div>
                    <div class="comms-command-email-day-grid">
                      <% comms_email_follow_up_day_labels.each do |day, label| %>
                        <label>
                          <span><%= label %></span>
                          <%= select_tag "follow_up[email][daily_plan][#{day}]", options_for_select(comms_email_follow_up_day_action_options, email_follow_up_plan[day].presence || "none"), class: "comms-command-launcher-input", data: { email_followup_day: day }, onchange: "window.wizwikiEmailFollowUpCustomDay&&window.wizwikiEmailFollowUpCustomDay(this)" %>
                        </label>
                      <% end %>
                    </div>
                  </section>
                  <footer class="comms-command-email-followup-actions">
                    <%= submit_tag "SAVE SCHEDULE", class: "comms-command-launcher-submit comms-command-launcher-submit--compact" %>
                  </footer>
                <% end %>
                <script>
                  window.wizwikiEmailFollowUpSync = function(panel) {
                    if (!panel) return
                    const preset = panel.querySelector("[data-email-followup-preset]")
                    const value = preset ? preset.value : "off"
                    const enabled = value !== "off"
                    const monthly = value === "monthly"
                    panel.querySelectorAll("[data-email-followup-monthly-only]").forEach((node) => {
                      node.hidden = !monthly
                      node.dataset.emailFollowupMonthlyActive = monthly ? "true" : "false"
                    })
                    const enabledField = panel.querySelector("[data-email-followup-enabled]")
                    if (enabledField) enabledField.value = enabled ? "1" : "0"
                    const cadence = panel.querySelector("[data-email-followup-cadence]")
                    if (cadence) cadence.value = enabled ? (monthly ? "monthly" : "weekly") : "off"
                    const frequencyBadge = panel.querySelector("[data-email-followup-frequency-badge]")
                    if (frequencyBadge) frequencyBadge.textContent = enabled ? `${monthly ? "30 DAY" : "1/DAY"} // SMS OFF WEEKENDS` : "OFF"
                    const badge = panel.querySelector("[data-email-followup-plan-badge]")
                    const mode = panel.querySelector("[data-email-followup-mode]")
                    if (badge) badge.textContent = enabled ? `${mode && mode.value === "custom" ? "CUSTOM" : (monthly ? "MONTHLY" : "PRESET")} // SMS OFF SAT/SUN` : "OFF"
                    if (monthly) {
                      const checks = Array.from(panel.querySelectorAll("[data-email-followup-week]"))
                      if (!checks.some((field) => field.checked)) {
                        checks.forEach((field) => { field.checked = true })
                      }
                    }
                  }
                  window.wizwikiEmailFollowUpPresetFill = function(select) {
                    const panel = select.closest("[data-email-followup-panel]")
                    if (!panel) return
                    let presets = {}
                    try { presets = JSON.parse(panel.dataset.emailFollowupPresets || "{}") } catch (error) { presets = {} }
                    const enabled = select.value !== "off"
                    const plan = enabled ? (presets[select.value] || {}) : (presets.off || {})
                    panel.querySelectorAll("[data-email-followup-day]").forEach((field) => {
                      field.value = plan[field.dataset.emailFollowupDay] || "none"
                    })
                    const mode = panel.querySelector("[data-email-followup-mode]")
                    if (mode) mode.value = "preset"
                    window.wizwikiEmailFollowUpSync(panel)
                  }
                  window.wizwikiEmailFollowUpCustomDay = function(select) {
                    const panel = select.closest("[data-email-followup-panel]")
                    if (!panel) return
                    const mode = panel.querySelector("[data-email-followup-mode]")
                    if (mode) mode.value = "custom"
                    window.wizwikiEmailFollowUpSync(panel)
                  }
                  window.wizwikiEmailFollowUpBind = function(root) {
                    const scope = root || document
                    scope.querySelectorAll("[data-email-followup-preset]").forEach((select) => {
                      if (select.dataset.emailFollowupBound === "true") return
                      select.dataset.emailFollowupBound = "true"
                      select.addEventListener("change", () => window.wizwikiEmailFollowUpPresetFill(select))
                      select.addEventListener("input", () => window.wizwikiEmailFollowUpPresetFill(select))
                      window.wizwikiEmailFollowUpSync(select.closest("[data-email-followup-panel]"))
                    })
                    scope.querySelectorAll("[data-email-followup-week]").forEach((field) => {
                      if (field.dataset.emailFollowupWeekBound === "true") return
                      field.dataset.emailFollowupWeekBound = "true"
                      field.addEventListener("change", () => window.wizwikiEmailFollowUpSync(field.closest("[data-email-followup-panel]")))
                    })
                  }
                  window.wizwikiEmailFollowUpBind(document)
                  document.addEventListener("turbo:load", () => window.wizwikiEmailFollowUpBind(document))
                </script>
              </section>
            </details>
          </div>
        </div>
        <div class="comms-command-win-menu comms-command-win-menu--edit" data-comms-win-menu>
