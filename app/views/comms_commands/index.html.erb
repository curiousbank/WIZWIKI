                <%= hidden_field_tag :q, @comms_query if @comms_query.present? %>
                <%= hidden_field_tag :status, @comms_status_filter if @comms_status_filter.present? %>
                <%= select_tag :board_state,
                  options_for_select(comms_board_state_options.map { |value, label| [label, value] }, stage_manual_board_state(stage)),
                  class: "comms-command-board-state-select",
                  aria: { label: "Board status for #{stage_company_name(stage)}" } %>
                <%= submit_tag "SET", class: "comms-command-board-state-submit" %>
              <% end %>
