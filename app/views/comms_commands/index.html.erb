                        // queued <%= number_with_delimiter(copilot_bulk_status["queued"].to_i) %>
                        // ready <%= number_with_delimiter(copilot_bulk_status["drafted"].to_i) %>
                        // skipped <%= number_with_delimiter(copilot_bulk_status["skipped"].to_i) %>
                        // failed <%= number_with_delimiter(copilot_bulk_status["failed"].to_i) %>
