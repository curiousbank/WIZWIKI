        class: "comms-command-icon-button comms-command-icon-button--claim",
        title: "Claim lead",
        aria: { label: "Claim #{stage_company_name(stage)}" } %>
    <% end %>

    <details class="comms-command-details comms-command-details--media">
      <summary class="comms-command-icon-button comms-command-icon-button--media" title="Media folder" aria-label="Media folder">
