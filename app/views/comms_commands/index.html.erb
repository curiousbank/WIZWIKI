                <option value="openai">⚡ OpenAI</option>
                <option value="qwen">🧠 Qwen Local 8B</option>
                <option value="qwen_9b">🧠 Qwen Local 9B MLX</option>
                <option value="qwen_30b">🧠 Qwen Local 30B</option>
