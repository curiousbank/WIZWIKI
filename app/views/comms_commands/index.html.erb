                        data: { comms_confirm_message: copilot_confirm, turbo_confirm: copilot_confirm },
                        onclick: copilot_disabled ? nil : comms_native_confirm_js.call(copilot_confirm) %>
                    <% end %>
                    <%= button_to "PURGE",
                      delete_all_comms_commands_path,
                      method: :delete,
                      params: { q: @comms_query.presence, status: @comms_status_filter, page: @comms_page },
                      disabled: remove_all_visible_count.zero?,
                      class: "comms-command-launcher-submit comms-command-launcher-submit--danger #{'comms-command-launcher-submit--blocked' if remove_all_visible_count.zero?}",
