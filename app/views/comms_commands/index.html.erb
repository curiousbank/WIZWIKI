                              <% inbound = event["direction"].to_s == "inbound" %>
                              <% latest_unanswered_inbound = inbound && has_new_inbound && event["provider_message_id"].to_s == stage.metadata.to_h["sms_listener_last_inbound_sid"].to_s %>
                              <% event_copy_line = [
                                event["created_at"],
                                event["direction"].presence || "outbound",
                                event["status"],
                                event["body"].to_s
                              ].compact_blank.join(" // ") %>
                              <div class="comms-command-bubble <%= event["status"] == "failed" ? "comms-command-bubble--failed" : (inbound ? "comms-command-bubble--inbound" : "comms-command-bubble--sent") %> <%= 'comms-command-bubble--new' if latest_unanswered_inbound %>" data-copy-line="<%= event_copy_line %>">
                                <small>
                                  <span><%= event["created_at"] %> // <%= event["direction"].presence || "outbound" %> // <%= event["status"] %></span>
                                  <button type="button" class="comms-command-copy-button comms-command-copy-button--mini" data-action="click->comms-station#copyText" data-copy-text="<%= event["body"].to_s %>">COPY</button>
                                </small>
                                <% if event["processing_code"].present? || event["processing_label"].present? %>
                                  <span class="comms-command-bubble-route">
                                    ROUTE // <%= event["processing_code"].presence || processing_code %><%= event["processing_label"].present? ? " // #{event["processing_label"]}" : "" %>
                                  </span>
                                <% end %>
                                <p data-copy-body><%= event["body"] %></p>
                                <% draft_time_label = event["draft_time_label"].presence || (event["draft_time_seconds"].present? ? "#{event["draft_time_seconds"].to_f.round(1)}s" : nil) %>
                                <% draft_model_label = event["draft_writer_model_label"].presence || event["draft_writer_model"].presence || event["draft_model"].presence %>
