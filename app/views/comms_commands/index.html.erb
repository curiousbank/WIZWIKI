            <textarea id="report_context_prompt_comms_<%= stage.id %>" name="report_context_prompt" rows="5" maxlength="1200" placeholder="Add direction for Thumper: offer angle, audience, tone, services to emphasize, things to avoid..." class="rpt-lab-copy-box"></textarea>
          </div>
          <% [["client", "🤝 Client-ready proposal."], ["am", "🧭 Internal AM brief."], ["copy_maker", "✒️ Local prep, selected cloud final."]].each do |audience, note| %>
