        <%= search_field_tag :q, @comms_query, placeholder: "Search any COMMS data", class: "comms-command-launcher-input" %>
        <%= submit_tag "SEARCH", class: "comms-command-launcher-submit" %>
        <% if @comms_query.present? %>
          <%= link_to "CLEAR", comms_command_path(status: @comms_status_filter, q: "", page: 1), class: "comms-command-search-clear" %>
        <% end %>
      <% end %>
      <%= form_with url: comms_command_path, method: :get, class: "comms-command-filter-form" do %>
        <%= hidden_field_tag :q, @comms_query if @comms_query.present? %>
        <label>
          <span>Show status</span>
          <%= select_tag :status,
            options_for_select(@comms_status_filter_options.map { |value, label|
              count = @comms_status_counts.to_h[value].to_i
              ["#{label} (#{number_with_delimiter(count)})", value]
            }, @comms_status_filter),
            class: "comms-command-launcher-input" %>
        </label>
        <%= submit_tag "SHOW", class: "comms-command-launcher-submit comms-command-launcher-submit--compact" %>
        <small>Hidden, complete, opt-out, and hold stay out of active runs.</small>
      <% end %>
      <% if @comms_query.present? %>
        <small class="comms-command-search-count"><%= pluralize(@stages.length, "matching COMMS block") %> shown for “<%= @comms_query %>”.</small>
      <% end %>
      <nav class="comms-command-pagination" aria-label="COMMS pages">
        <% if @comms_has_previous_page %>
          <%= link_to "⏪", comms_command_path(q: @comms_query.presence, status: @comms_status_filter.presence, page: @comms_page - 1), class: "comms-command-page-block", title: "Previous 100" %>
        <% else %>
          <span class="comms-command-page-block comms-command-page-block--disabled">⏪</span>
        <% end %>
        <span class="comms-command-page-range">
          <b><%= number_with_delimiter(@comms_page_start.to_i) %>-<%= number_with_delimiter(@comms_page_end.to_i) %></b>
          <small>Page <%= @comms_page %> // max <%= number_with_delimiter(@comms_page_size.to_i) %></small>
        </span>
        <% if @comms_has_next_page %>
          <%= link_to "⏩", comms_command_path(q: @comms_query.presence, status: @comms_status_filter.presence, page: @comms_page + 1), class: "comms-command-page-block", title: "Next 100" %>
        <% else %>
          <span class="comms-command-page-block comms-command-page-block--disabled">⏩</span>
        <% end %>
      </nav>
    </div>
  </section>

  <% comms_discovery_version = ->(stage) do
    metadata = stage.metadata.to_h
    bot_state = metadata["comms_bot_state"].to_h
    [
      stage_processing_code(stage),
      bot_state.values_at(
        "route_code",
        "contact_name",
        "company_name",
        "autopilot_complete"
      ),
      metadata.values_at(
        "captured_contact_name",
        "captured_company_name",
        "product_interest_code",
        "product_interest_label",
        "shopify_link",
        "shopify_link_sent_at",
        "sms_autopilot_completed_at",
        "sms_autopilot_completion_sent_at",
        "sms_autopilot_slack_human_requested_at",
        "sms_autopilot_slack_completion_without_purchase_at",
        "sms_autopilot_slack_handoff_at",
        "comms_support_state",
        "sms_do_not_contact",
        "sms_do_not_contact_at",
        "sms_do_not_contact_reason"
      )
    ].flatten.compact_blank.map(&:to_s).join(":")
  end %>

  <% comms_board_version = @stages.map { |stage|
    metadata = stage.metadata.to_h
    sms_thread = Array(metadata["sms_thread"])
    [
      stage.id,
      stage.updated_at.to_f,
      stage.status,
      comms_discovery_version.call(stage),
      sms_thread.length,
      sms_thread.last.to_h["id"],
      sms_thread.last.to_h["provider_message_id"],
      metadata["comms_command_last_status"],
      metadata["shopify_link_sent_at"],
      metadata["sms_autopilot_slack_human_requested_at"],
      metadata["sms_autopilot_slack_completion_without_purchase_at"],
      metadata["sms_autopilot_slack_handoff_at"],
      metadata["comms_support_state"],
      metadata["sms_do_not_contact_at"],
      metadata["sms_do_not_contact_reason"],
      metadata["sms_listener_last_outbound_sid"],
      Digest::SHA1.hexdigest(metadata["comms_command_sms_draft_body"].to_s)[0, 12],
      metadata["comms_command_background_question_id"],
      metadata["comms_command_background_status"],
      metadata["comms_board_state"],
      metadata["comms_bulk_run_id"],
      metadata["comms_bulk_run_status"],
      metadata["comms_bulk_run_updated_at"],
      metadata.dig("comms_bulk_run", "position"),
      metadata.dig("comms_bulk_run", "stage_count"),
      @comms_status_filter
    ].compact.join(":")
  }.join("|") %>
  <div class="comms-command-board"
       role="region"
       aria-label="Staged communications schedule"
       data-controller="comms-board"
       data-comms-board-url-value="<%= comms_command_path(q: @comms_query.presence, status: @comms_status_filter.presence, page: @comms_page) %>"
       data-comms-board-version-url-value="<%= comms_board_version_path %>"
       data-comms-board-change-token-value="<%= @comms_board_change_token %>"
       data-comms-board-version-value="<%= comms_board_version %>"
       data-comms-board-interval-value="15000">
    <div class="comms-command-board-head">
      <span>TRACK</span>
      <span>COMPANY</span>
      <span>CONTACT</span>
      <span>NUMBER</span>
      <span>EMAIL</span>
      <span>COMMANDS</span>
    </div>

    <% if @stages.present? %>
      <% @stages.each_with_index do |stage, index| %>
        <% contact = stage_selected_contact(stage).to_h %>
        <% phone = stage_selected_phone(stage).to_h %>
        <% email = stage_selected_email(stage).to_h %>
        <% sms_body = stage_sms_body(stage) %>
        <% sms_draft = stage.metadata.to_h["comms_command_sms_draft"].to_h %>
        <% sms_prompt = stage.metadata.to_h["comms_command_sms_prompt"].to_s %>
        <% email_subject = stage_email_subject(stage) %>
        <% email_body = stage_email_body(stage) %>
        <% email_prompt = stage.metadata.to_h["comms_command_email_prompt"].to_s %>
        <% sms_thread = stage_sms_thread(stage) %>
        <% sms_reset_at = stage_sms_conversation_reset_time(stage) %>
        <% sms_discovery_reset = sms_reset_at.present? && ActiveModel::Type::Boolean.new.cast(stage.metadata.to_h["sms_discovery_reset"]) %>
        <% sms_thread_after_reset = stage_sms_events_after_reset(stage) %>
        <% sms_customer_signal_after_reset = sms_thread_after_reset.any? do |event|
          event = event.to_h
          event["channel"].to_s == "sms" && event["direction"].to_s == "inbound" && event["body"].to_s.squish.present?
        end %>
        <% sms_product_reset_pending = sms_discovery_reset && !sms_customer_signal_after_reset %>
        <% email_thread = stage_email_thread(stage) %>
        <% tel_href = tel_href_for(phone["value"]) %>
        <% processing_code = stage_processing_code(stage) %>
        <% processing_summary = stage_processing_summary(stage) %>
        <% if sms_product_reset_pending %>
          <% processing_code = nil %>
          <% processing_summary = "Route pending. Thumper is waiting for a customer signal in the chat." %>
        <% end %>
        <% has_new_inbound = stage_recent_inbound_sms?(stage) %>
        <% sms_do_not_contact = stage_sms_do_not_contact?(stage) %>
        <% sms_sending_disabled = sms_do_not_contact || ActiveModel::Type::Boolean.new.cast(stage.metadata.to_h["sms_sending_disabled"]) %>
        <% sms_listener_active = !sms_do_not_contact && ActiveModel::Type::Boolean.new.cast(stage.metadata.to_h["sms_listener_active"]) %>
        <% sms_autopilot_enabled = stage_sms_autopilot_enabled?(stage) %>
        <% sms_background_drafting = stage_sms_background_drafting?(stage) %>
        <% sms_progress_live = sms_background_drafting %>
        <% sms_progress_label = "Thumper COMPOSING" %>
        <% draft_progress_started_at = stage.metadata.to_h["comms_command_background_at"].presence || sms_draft["created_at"].presence %>
        <% sms_progress_signals = sms_progress_live ? stage_sms_draft_progress_signals(stage) : [] %>
        <% sms_first_sent = stage_first_sms_sent?(stage) %>
        <% sms_watchdog = stage.metadata.to_h["sms_no_ghost_watchdog"].to_h %>
        <% sms_pre_send_review = stage.metadata.to_h["sms_pre_send_verifier_last"].to_h %>
        <% sms_callblock = !sms_do_not_contact && (
          sms_watchdog["status"].to_s == "needs_attention" ||
          stage.metadata.to_h["sms_reply_job_status"].to_s == "needs_attention" ||
          sms_pre_send_review["status"].to_s == "blocked"
        ) %>
        <% sms_callblock_reason = if sms_watchdog["status"].to_s == "needs_attention"
          sms_watchdog["reason"].presence || "SMS watchdog needs human attention"
        elsif sms_pre_send_review["status"].to_s == "blocked"
          sms_pre_send_review["reason"].presence || "Pre-send verifier blocked the next SMS"
        else
          stage.metadata.to_h["sms_autopilot_last_error"].presence || "Thumper needs human attention before the next SMS"
        end %>
        <% sms_attn_event = stage_latest_inbound_sms_event(stage) %>
        <% sms_recent_client_reply = stage_recent_client_sms_response?(stage) %>
        <% sms_attention = sms_callblock || (sms_recent_client_reply && sms_first_sent && !sms_do_not_contact) %>
        <% sms_attn_active = sms_attention %>
        <% sms_attn_started_at = sms_callblock ? (sms_watchdog["checked_at"].presence || sms_pre_send_review["checked_at"].presence || Time.current.iso8601) : (sms_attn_event.to_h["created_at"].presence || sms_attn_event.to_h["at"].presence || sms_attn_event.to_h["timestamp"].presence || Time.current.iso8601) %>
        <% bot_state = stage.metadata.to_h["comms_bot_state"].to_h %>
        <% generic_comms_label = ->(value) do
          text = value.to_s.squish.downcase
          text.blank? || text.match?(/\A(?:wizwiki\s*)?comms\b/) || text.match?(/\Amanual\s+comms\b/) || text.match?(/\Achoose\s+in\s+lab\b/)
        end %>
        <% generic_identity = ->(value) do
          text = value.to_s.squish.downcase
          text.blank? || %w[wizwiki\ comms sample\ comms manual\ comms choose\ in\ lab contact customer].include?(text) || text.match?(/\A(?:wizwiki\s*)?comms\b/) || text.match?(/\Asample\b/)
        end %>
        <% same_identity = ->(left, right) do
          normalize = ->(value) { value.to_s.downcase.gsub(/[^a-z0-9]/, "") }
          left_key = normalize.call(left)
          right_key = normalize.call(right)
          left_key.present? && right_key.present? && left_key == right_key
        end %>
        <% bot_contact_name = bot_state["contact_name"].presence || (sms_discovery_reset ? nil : stage.metadata.to_h["captured_contact_name"].presence || contact["name"].presence) %>
        <% bot_contact_name = nil if generic_identity.call(bot_contact_name) %>
        <% bot_company_name = bot_state["company_name"].presence || (sms_discovery_reset ? nil : stage.metadata.to_h["captured_company_name"].presence || stage_company_name(stage)) %>
        <% bot_company_name = nil if generic_identity.call(bot_company_name) %>
        <% bot_company_name = nil if same_identity.call(bot_company_name, bot_contact_name) %>
        <% bot_route = sms_product_reset_pending ? "pending" : (stage.metadata.to_h["product_interest_code"].presence || bot_state["route_code"].presence || "pending") %>
<% bot_product_label = sms_product_reset_pending ? nil : (stage.metadata.to_h["product_interest_label"].presence || bot_state["route_label"].presence || bot_route.to_s.tr("_", " ").titleize) %>
<% bot_owner = stage.metadata.to_h["comms_routed_to_user_name"].presence || stage.metadata.to_h["comms_routed_to_user_email"].presence %>
<% bot_contact_owner_status = bot_owner.present? ? bot_owner : (sms_autopilot_enabled ? "running" : "pending") %>
<% bot_route_known = bot_route.present? && bot_route != "pending" %>
<% bot_campaign_fit = bot_state["campaign_fit"].to_h %>
<% bot_industry = bot_state["industry"].presence || (sms_discovery_reset ? nil : stage.metadata.to_h["captured_industry"].presence || stage.metadata.to_h["industry"].presence) %>
<% bot_email = sms_discovery_reset ? nil : stage.metadata.to_h["captured_email"].presence || email["email"].presence || email["value"].presence %>
<% bot_email_opt_in = sms_discovery_reset ? nil : stage.metadata.to_h["email_opt_in"].presence %>
<% bot_contact_preference = sms_discovery_reset ? nil : stage.metadata.to_h["contact_preference"].presence %>
<% bot_preferred_contact_window = sms_discovery_reset ? nil : stage.metadata.to_h["preferred_contact_window"].presence || stage.metadata.to_h["preferred_contact_days"].presence || stage.metadata.to_h["preferred_contact_times"].presence %>
<% bot_proof_delivery = sms_discovery_reset ? nil : stage.metadata.to_h["proof_delivery_email"].presence || stage.metadata.to_h["proof_delivery_method"].presence %>
<% contact_snapshot_active = bot_email.present? || bot_email_opt_in.present? || bot_contact_preference.present? || bot_preferred_contact_window.present? || bot_proof_delivery.present? %>
<% inbound_thread_text = sms_thread_after_reset.filter_map { |event| event.to_h["direction"].to_s == "inbound" ? event.to_h["body"].to_s : nil }.join(" ") %>
<% inferred_budget_match = inbound_thread_text.match(/\b(?:no budget|open budget|flexible budget|no cap|no limit)\b|\$\s?[\d,]+|\b[\d,.]+\s*[km]\b(?!\s*(?:homes?|houses?|households?|doors?|addresses?|mailboxes?|signs?))|\b(?:budget|spend|around|under|up to)\s+\$?[\d,.]+\s*[km]?\b/i) %>
<% inferred_size_match = inbound_thread_text.match(/\b[\d,]{1,6}\s*(?:homes?|houses?|households?|doors?|addresses?|mailboxes?|yard signs?|lawn signs?|signs?|postcards?|mailers?|door hangers?)\b/i) %>
<% inferred_artwork_match = inbound_thread_text.match(/\b(?:artwork|design|creative|logo|file|layout|ai design|designer|designers)\b/i) %>
<% fit_budget_value = bot_campaign_fit["budget"].presence || inferred_budget_match.to_s.presence %>
<% fit_size_value = bot_campaign_fit["quantity_count"].presence || bot_campaign_fit["household_count"].presence || inferred_size_match.to_s.presence %>
<% fit_artwork_value = bot_campaign_fit["artwork_status"].presence || inferred_artwork_match.to_s.presence %>
<% fit_budget_known = fit_budget_value.present? %>
<% fit_size_known = fit_size_value.present? %>
<% fit_artwork_known = fit_artwork_value.present? %>
<% link_sent = stage_link_sent?(stage) %>
<% am_support = stage.metadata.to_h["sms_autopilot_slack_human_requested_at"].present? ||
  stage.metadata.to_h["sms_autopilot_slack_completion_without_purchase_at"].present? ||
  stage.metadata.to_h["sms_autopilot_slack_handoff_at"].present? ||
  stage.metadata.to_h["comms_support_state"].to_s == "am_support" ||
  stage.metadata.to_h["comms_command_last_status"].to_s.in?(%w[human_requested account_manager_support am_support]) ||
  stage.metadata.to_h["comms_route_claim_reason"].to_s.match?(/\b(human_requested|account_manager_answer_needed)\b/) %>
<% discovery_checks = [
  ["product", bot_route_known],
  ["budget", fit_budget_known],
  ["size", fit_size_known],
  ["artwork", fit_artwork_known],
  ["name", bot_contact_name.present?],
  ["company", bot_company_name.present?],
  ["link", link_sent]
] %>
<% discovery_done = discovery_checks.count { |_label, done| done } %>
<% discovery_total = discovery_checks.length %>
<% discovery_percent = ((discovery_done.to_f / discovery_total) * 100).round %>
<% discovery_complete = discovery_done == discovery_total %>
<% discovery_next = discovery_checks.find { |_label, done| !done }&.first %>
<% discovery_next_label = discovery_complete ? "ready" : discovery_next.to_s.tr("_", " ") %>
<% completion_marked = stage.metadata.to_h["sms_autopilot_completed_at"].present? || stage.metadata.to_h["sms_autopilot_completion_sent_at"].present? || ActiveModel::Type::Boolean.new.cast(bot_state["autopilot_complete"]) %>
	<% sms_autopilot_complete = discovery_complete && link_sent && completion_marked && !has_new_inbound %>
	<% comms_watch_active = !sms_do_not_contact && (sms_listener_active || sms_autopilot_enabled || has_new_inbound || !sms_autopilot_complete) %>
	<% follow_up_timer = stage_follow_up_timer(stage) %>
	<% call_status = stage_call_status(stage, follow_up_timer: follow_up_timer) %>
	<% call_status_key = call_status[:key].to_s %>
	<% card_status_label = call_status_key == "autopilot" ? nil : call_status[:label] %>
	<% card_status_label = "CALLBLOCK" if sms_callblock %>
	<% call_status_class = "comms-command-row--status-#{call_status_key.tr('_', '-')}" %>
<% card_direction_label = stage.metadata.to_h["comm_kit_direction_label"].presence %>
<% card_direction_label = nil if generic_comms_label.call(card_direction_label) %>
<% card_contact_label = contact["name"].presence %>
<% card_contact_label = nil if generic_identity.call(card_contact_label) %>
	<% card_company_label = stage.metadata.to_h["company_name"].presence || stage.metadata.to_h["captured_company_name"].presence || bot_company_name.presence || stage_company_name(stage) %>
<% card_company_label = nil if generic_comms_label.call(card_company_label) || same_identity.call(card_company_label, card_contact_label) || same_identity.call(card_company_label, bot_contact_name) %>
        <% comms_record = stage.crm_record %>
<% report_artifacts = @report_artifacts_by_record_id.to_h.fetch(comms_record&.id, []) %>
<% report_artifacts = report_artifacts.sort_by(&:created_at).reverse %>
<% client_report_count = report_artifacts.count { |artifact| (artifact.metadata.to_h["report_audience"].presence || "client").to_s == "client" } %>
<% am_report_count = report_artifacts.count { |artifact| artifact.metadata.to_h["report_audience"].to_s == "am" } %>
<% copy_maker_report_count = report_artifacts.count { |artifact| artifact.metadata.to_h["report_audience"].to_s == "copy_maker" } %>
<% active_client_report = report_artifacts.find { |artifact| artifact.status.to_s.in?(%w[queued generating report_ready]) && (artifact.metadata.to_h["report_audience"].presence || "client").to_s == "client" } %>
<% active_am_report = report_artifacts.find { |artifact| artifact.status.to_s.in?(%w[queued generating report_ready]) && artifact.metadata.to_h["report_audience"].to_s == "am" } %>
<% active_copy_maker_report = report_artifacts.find { |artifact| artifact.status.to_s.in?(%w[queued generating report_ready]) && artifact.metadata.to_h["report_audience"].to_s == "copy_maker" } %>
<% active_report = active_client_report || active_am_report || active_copy_maker_report %>
<% latest_doc_report = report_artifacts.find(&:report_ready?) %>
<% latest_kit_report = report_artifacts.find(&:canva_kit_ready?) %>
<% docs_ready_report = report_artifacts.find { |artifact| artifact.status.to_s.in?(%w[report_ready canva_kit_ready ready archived]) } %>
<% docs_ready_count = report_artifacts.count { |artifact| artifact.status.to_s.in?(%w[report_ready canva_kit_ready ready archived]) } %>
<% active_report_audience = active_report&.metadata.to_h["report_audience"].presence || "client" %>
<% active_report_label = active_report_audience.to_s == "copy_maker" ? "COPY" : active_report_audience.to_s.upcase %>
        <% media_attachments = comms_record&.deal_media&.attachments&.to_a || [] %>
        <% record_claimed_by_me = comms_record&.owner_id.present? && comms_record.owner_id == current_user.id %>
        <% record_claimed = comms_record&.owner_id.present? %>
        <% record_claim_label = record_claimed_by_me ? "you" : (comms_record&.owner&.display_name.presence || "AM") %>
        <% sms_thread_last = sms_thread.last.to_h %>
        <% bulk_run = stage.metadata.to_h["comms_bulk_run"].to_h %>
        <% bulk_run_status = bulk_run["status"].to_s.presence || stage.metadata.to_h["comms_bulk_run_status"].to_s.presence %>
        <% bulk_run_mode = bulk_run["mode"].to_s.presence || stage.metadata.to_h["comms_bulk_run_mode"].to_s.presence %>
        <% bulk_run_label = bulk_run_mode == "copilot" ? "COPILOT" : "FULL AUTO" %>
        <% bulk_run_id = bulk_run["run_id"].to_s.presence || stage.metadata.to_h["comms_bulk_run_id"].to_s.presence %>
        <% bulk_run_position = bulk_run["position"].presence || stage.metadata.to_h["comms_bulk_run_position"].presence %>
        <% bulk_run_stage_count = bulk_run["stage_count"].presence || stage.metadata.to_h["comms_bulk_run_stage_count"].presence %>
        <% comms_station_version = [
          stage.updated_at.to_f,
          sms_thread.length,
          Digest::SHA1.hexdigest(sms_thread.map { |event| event.to_h.slice("direction", "status", "body", "provider_message_id", "created_at") }.to_json)[0, 12],
          sms_thread_last["id"],
          sms_thread_last["provider_message_id"],
          sms_thread_last["created_at"],
          sms_draft["created_at"],
          Digest::SHA1.hexdigest(stage.metadata.to_h["comms_command_sms_draft_body"].to_s)[0, 12],
          comms_discovery_version.call(stage),
          bot_email,
          bot_email_opt_in,
          bot_contact_preference,
          bot_preferred_contact_window,
          stage.metadata.to_h["comms_command_last_status"],
          stage.metadata.to_h["comms_command_background_question_id"],
          stage.metadata.to_h["comms_command_background_status"],
          stage.metadata.to_h["sms_listener_last_outbound_sid"],
          bulk_run_id,
          bulk_run_status,
          bulk_run["updated_at"],
          bulk_run_position,
          bulk_run_stage_count,
          active_report&.updated_at&.to_f,
          latest_doc_report&.id,
          latest_doc_report&.status,
          latest_kit_report&.id
        ].compact.join(":") %>
        <article id="stage-<%= stage.id %>"
		          class="comms-command-row <%= call_status_class %> <%= 'comms-command-row--fresh' unless sms_first_sent %> <%= 'comms-command-row--sent' if sms_first_sent %> <%= 'comms-command-row--new-inbound comms-command-row--attention' if sms_attention %> <%= 'comms-command-row--callblock' if sms_callblock %> <%= 'comms-command-row--listening' if sms_listener_active %> <%= 'comms-command-row--autopilot' if sms_autopilot_enabled %> <%= 'comms-command-row--drafting' if sms_background_drafting %> <%= 'comms-command-row--report-running' if active_report.present? %> <%= 'comms-command-row--docs-ready' if docs_ready_report.present? %> <%= 'comms-command-row--stale-due' if follow_up_timer[:state].to_s == 'due' %> <%= 'comms-command-row--complete' if sms_autopilot_complete %> <%= 'comms-command-row--link-sent' if link_sent %> <%= 'comms-command-row--am-support' if am_support %> <%= 'comms-command-row--do-not-contact' if sms_do_not_contact %>"
          data-controller="comms-station"
          data-comms-station-url-value="<%= live_comms_command_path(stage) %>"
          data-comms-station-stage-id-value="<%= stage.id %>"
data-comms-station-version-value="<%= comms_station_version %>"
data-comms-station-watch-value="<%= (@comms_open_sms_stage_id.presence || params[:open_sms_stage].to_s).to_s == stage.id.to_s %>"
data-comms-station-interval-value="5000">

