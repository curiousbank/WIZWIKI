                      form: { data: { comms_confirm_message: remove_all_confirm, turbo_confirm: remove_all_confirm }, onsubmit: comms_confirm_onsubmit_js } %>
                  </div>
                  <% if @run_all_blocked_by_visible_dnc %>
                    <small class="comms-command-runall-warning">FULL AUTO is locked because a visible block is marked DO NOT CONTACT. COPILOT will skip opt-outs because it only drafts.</small>
                  <% end %>
                  <% if bulk_status["state"].present? %>
                    <small class="comms-command-runall-warning comms-command-runall-warning--queue">
                      BULK QUEUE // <%= bulk_status["state"].to_s.upcase %>
                      <% if bulk_status["stage_count"].to_i.positive? %>
                        // <%= number_with_delimiter(bulk_status["current_index"].to_i) %>/<%= number_with_delimiter(bulk_status["stage_count"].to_i) %>
