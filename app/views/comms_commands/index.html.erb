                                  <small class="comms-command-twilio-meta">
                                    <%= compact_twilio_context.presence.to_h.map { |key, value| "#{twilio_labels.fetch(key.to_s, key.to_s)}: #{value}" }.join(" // ") %>
                                  </small>
                                <% end %>
                                <% if event["error"].present? %>
                                  <em><%= event["error"] %></em>
                                <% end %>
                              </div>
                            <% end %>
                          <% else %>
                            <p class="comms-command-empty">No SMS in this thread yet. Thumper has staged the first outbound text below.</p>
                          <% end %>
                          <span class="comms-command-chat-latest-end" aria-hidden="true"></span>
                          <span class="comms-command-chat-end" aria-hidden="true"></span>
                        </div>
