                <option value="<%= option[:value] %>"><%= option[:label] %></option>
              <% end %>
            </select>
          </label>
          <div class="rpt-lab-copy-dock">
            <label for="copy_maker_cloud_provider_comms_<%= stage.id %>" class="rpt-lab-cloud-control" data-rpt-builder-target="cloudDock" hidden>
              <span>☁️ COPY POST PAYLOAD</span>
              <select id="copy_maker_cloud_provider_comms_<%= stage.id %>" name="copy_maker_cloud_provider" class="rpt-lab-cloud-select">
