	                        <%= submit_tag(sms_do_not_contact ? "DO NOT CONTACT" : (sms_autopilot_complete ? "✓ COMPLETE" : (sms_autopilot_enabled ? "✈️ AUTOPILOT RUNNING" : "✈️ START AUTOPILOT")), disabled: sms_do_not_contact || sms_autopilot_complete, class: "comms-command-autopilot-button #{'comms-command-autopilot-button--on' if sms_autopilot_enabled} #{'comms-command-autopilot-button--complete' if sms_autopilot_complete} #{'comms-command-autopilot-button--blocked' if sms_do_not_contact}", data: { comms_confirm_message: overlay_autopilot_confirm, turbo_confirm: overlay_autopilot_confirm }) %>
