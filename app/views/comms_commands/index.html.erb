              <span><b>email</b><strong><%= bot_email %></strong></span>
            <% elsif bot_email_opt_in.present? %>
              <span><b>email</b><strong><%= bot_email_opt_in == "no" ? "declined" : bot_email_opt_in %></strong></span>
            <% end %>
            <% if bot_contact_preference.present? %>
              <span><b>pref</b><strong><%= bot_contact_preference %></strong></span>
            <% end %>
            <% if bot_preferred_contact_window.present? %>
              <span><b>follow-up</b><strong><%= bot_preferred_contact_window %></strong></span>
            <% end %>
            <% if bot_proof_delivery.present? %>
              <span><b>proofs</b><strong><%= bot_proof_delivery %></strong></span>
            <% end %>
          </div>

          <% if active_report.present? %>
            <div class="comms-command-report-timer"
                 data-report-card-timer
                 data-report-card-timer-started-at="<%= active_report.created_at&.iso8601 %>"
                 data-report-card-timer-status="<%= active_report.status %>"
                 data-report-card-timer-label="<%= active_report_label %>">
              <div>
                <b>RPT #<%= active_report.id %> // <%= active_report_label %> // <%= active_report.status.to_s.tr("_", " ") %></b>
                <span>Thumper building documents</span>
              </div>
              <em data-report-card-timer-label><%= active_report.created_at ? "#{time_ago_in_words(active_report.created_at)} running" : "running" %></em>
            </div>
          <% end %>

          <% if bulk_run_id.present? %>
            <div class="comms-command-report-timer comms-command-report-timer--bulk">
              <div>
                <b>
                  <%= bulk_run_label %>
                  <% if bulk_run_position.present? && bulk_run_stage_count.present? %>
                    // <%= number_with_delimiter(bulk_run_position.to_i) %>/<%= number_with_delimiter(bulk_run_stage_count.to_i) %>
                  <% end %>
                  // BLOCK #<%= stage.id %>
                </b>
                <span>
                  Run <%= bulk_run_id.first(8) %>
                  <% if bulk_run["page"].present? %>
                    // page <%= bulk_run["page"] %>
                  <% end %>
                  <% if bulk_run["launch_cadence_label"].present? %>
                    // pace <%= bulk_run["launch_cadence_label"] %>
                  <% end %>
                  <% if bulk_run["detail"].present? %>
                    // <%= bulk_run["detail"] %>
                  <% end %>
                </span>
              </div>
              <em><%= bulk_run_status.to_s.presence&.upcase || "QUEUED" %></em>
            </div>
          <% end %>

          <% contact_detail = [contact["title"], contact["record_type"], contact["reason"]].compact_blank.join(" // ") %>
          <% phone_detail = phone["name"].presence || phone["reason"].presence || "CRM phone route" %>
          <% email_detail = email["name"].presence || email["reason"].presence || "CRM email route" %>
          <div class="comms-command-contact-grid" aria-label="Primary contact details">
            <div class="comms-command-contact-field comms-command-contact-field--name">
              <span>Contact</span>
              <b title="<%= card_contact_label.presence || 'Contact needed' %>"><%= card_contact_label.presence || "contact needed" %></b>
              <small title="<%= contact_detail %>"><%= contact_detail %></small>
            </div>
            <div class="comms-command-contact-field comms-command-contact-field--phone">
              <span>Phone</span>
              <b title="<%= phone["value"].presence || 'No phone' %>"><%= phone["value"].presence || "no phone" %></b>
              <small title="<%= phone_detail %>"><%= phone_detail %></small>
            </div>
            <div class="comms-command-contact-field comms-command-contact-field--company">
              <span>Company</span>
              <b title="<%= card_company_label.presence || 'Company needed' %>"><%= card_company_label.presence || "company needed" %></b>
              <small title="<%= bot_industry.presence || 'CRM company' %>"><%= bot_industry.presence || "CRM company" %></small>
            </div>
            <div class="comms-command-contact-field comms-command-contact-field--email">
              <span>Email</span>
              <b title="<%= email["value"].presence || 'No email' %>"><%= email["value"].presence || "no email" %></b>
              <small title="<%= email_detail %>"><%= email_detail %></small>
            </div>
          </div>
<div class="comms-command-actions">
  <div class="comms-command-action-row comms-command-action-row--reports">
