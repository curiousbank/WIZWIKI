                      <% if bulk_status.dig("source", "launch_cadence_label").present? %>
                        // pace <%= bulk_status.dig("source", "launch_cadence_label") %>
                      <% end %>
                      <% if bulk_status.dig("source", "static_sms_template", "title").present? %>
                        // template <%= bulk_status.dig("source", "static_sms_template", "title").to_s.truncate(32) %>
                      <% end %>
                      <% if bulk_status.dig("source", "stage_ids").present? %>
                        // fixed snapshot
