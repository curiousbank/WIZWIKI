	                        </div>
		                        <%= form_with url: draft_comms_sms_path(stage), method: :post, class: "comms-command-compose comms-command-compose--tight", data: { turbo: false, action: "submit->comms-station#submit" } do %>
	                          <%= hidden_field_tag :sms_writer_model, stage_sms_writer_model(stage), data: { sms_writer_stage: stage.id } %>
	                          <label>
	                            <span>Prompt</span>
	                            <%= text_area_tag :sms_prompt, sms_prompt, rows: 5, maxlength: 700, placeholder: "Leave blank for a fresh next text, or guide Thumper: ask what they need, share a Shopify link, make it warmer." %>
                          </label>
	                          <%= submit_tag "GENERATE NEXT TEXT", class: "comms-command-send comms-command-send--rewrite" %>
                        <% end %>
                        <p class="comms-command-bot-note">
                          Empty prompt builds a fresh next move from the chat. Filled prompt guides Thumper without sending automatically.
                        </p>
                      </section>
                    </div>
                  </div>
                </div>
              </div>
              <% else %>
              <div class="comms-command-communicator comms-command-communicator--phone comms-command-communicator--lazy" data-comms-lazy-station="true">
                <div class="comms-command-windowbar">
                  <span class="comms-command-windowbar-phone" aria-hidden="true">📱</span>
                  <b>Thumper SMS // <%= phone["value"].presence || "NO NUMBER" %></b>
                  <%= button_tag "X", type: "button", class: "comms-command-overlay-close", data: { action: "click->comms-station#closeOverlay" }, aria: { label: "Close SMS overlay" } %>
                </div>
                <div class="comms-command-phone-face comms-command-lazy-station">
                  <div class="comms-command-lazy-loader" role="status" aria-live="polite">
                    <b>Opening Thumper SMS station</b>
                    <span>Loading the current thread...</span>
                  </div>
                </div>
              </div>
              <% end %>
            </details>
            <details class="comms-command-details" <%= "open" if params[:open_email_stage].to_s == stage.id.to_s %>>
              <summary class="comms-command-icon-button comms-command-icon-button--email" title="Open email draft" aria-label="Open email draft">✉️</summary>
              <div class="comms-command-communicator">
                <div class="comms-command-windowbar">
                  <span></span><span></span><span></span>
                  <b>EMAIL // <%= email["value"].presence || "NO EMAIL" %></b>
                  <%= button_tag "X", type: "button", class: "comms-command-overlay-close", data: { action: "click->comms-station#closeOverlay" }, aria: { label: "Close email overlay" } %>
                </div>
                <% if email_thread.present? %>
                  <div class="comms-command-chatlog">
                    <% email_thread.each do |event| %>
                      <% event = event.to_h %>
                      <div class="comms-command-bubble <%= event["status"] == "failed" ? "comms-command-bubble--failed" : "comms-command-bubble--sent" %>">
                        <small><%= event["created_at"] %> // <%= event["status"] %></small>
                        <p><b><%= event["subject"] %></b></p>
                        <p><%= event["body"] %></p>
                        <% if event["error"].present? %>
                          <em><%= event["error"] %></em>
                        <% end %>
                      </div>
                    <% end %>
                  </div>
                <% end %>
                <%= form_with url: draft_comms_email_path(stage), method: :post, class: "comms-command-compose comms-command-compose--tight", data: { turbo: false } do %>
                  <label>
                    <span>Prompt email</span>
                    <%= text_area_tag :email_prompt, email_prompt, rows: 3, maxlength: 900, placeholder: "Tell Thumper what this email should do: recommend a product, answer a question, follow up from the SMS thread, or write a warmer intro using this account context..." %>
                  </label>
                  <%= submit_tag "PROMPT EMAIL", class: "comms-command-send" %>
                <% end %>
                <%= form_with url: send_comms_email_path(stage), method: :post, class: "comms-command-compose" do %>
                  <label>
                    <span>Send to email</span>
                    <%= email_field_tag :email_to, email["value"], maxlength: 180, placeholder: "name@example.com", required: true %>
                  </label>
                  <label>
                    <span>Subject</span>
                    <%= text_field_tag :email_subject, email_subject, maxlength: 160 %>
                  </label>
                  <label>
                    <span>Approved email</span>
                    <%= text_area_tag :email_body, email_body, rows: 8, maxlength: 3_000 %>
                  </label>
                  <%= submit_tag "SEND EMAIL", class: "comms-command-send", data: { turbo_confirm: "Send this email to #{email["value"].presence || "the selected recipient"}?" } %>
                <% end %>
              </div>
            </details>
<% autopilot_confirm = sms_autopilot_enabled ? "Pause Thumper autopilot for this SMS thread?" : "Start Thumper autopilot listening for this SMS thread? This will not send the current NEXT TEXT. Use FULL AUTO from the board for automatic launch." %>
<%= button_to "✈️",
  toggle_comms_autopilot_path(stage),
  method: :patch,
  params: { enabled: sms_autopilot_enabled ? "0" : "1", return_to_board: "1" },
  form: { class: "comms-command-autopilot-icon-form", data: { comms_confirm_message: autopilot_confirm, turbo_confirm: autopilot_confirm }, onsubmit: comms_confirm_onsubmit_js },
  class: "comms-command-icon-button comms-command-icon-button--autopilot #{'comms-command-icon-button--autopilot-on' if sms_autopilot_enabled} #{'comms-command-icon-button--autopilot-complete' if sms_autopilot_complete}",
  disabled: sms_do_not_contact || sms_autopilot_complete,
  title: sms_do_not_contact ? "Do not contact" : (sms_autopilot_complete ? "Autopilot complete" : (sms_autopilot_enabled ? "Pause Thumper autopilot" : "Start Thumper autopilot")),
  aria: { label: sms_autopilot_enabled ? "Pause autopilot for #{stage_company_name(stage)}" : "Start autopilot for #{stage_company_name(stage)}" },
  data: { comms_confirm_message: autopilot_confirm, turbo_confirm: autopilot_confirm } %>

            <% sos_confirm = "Send this call to AM help and post to Owner Queue?" %>
            <%= button_to "🆘", send_to_am_comms_path(stage), method: :patch,
              params: { q: @comms_query.presence, status: @comms_status_filter.presence, reason: "manual_am_support" }.compact,
              form: { class: "comms-command-inline-form", data: { comms_confirm_message: sos_confirm, turbo_confirm: sos_confirm }, onsubmit: comms_confirm_onsubmit_js },
              class: "comms-command-icon-button comms-command-icon-button--am-help",
              disabled: sms_do_not_contact,
              title: "Send to AM help",
              aria: { label: "Send #{stage_company_name(stage)} to AM help" },
              data: { comms_confirm_message: sos_confirm, turbo_confirm: sos_confirm } %>

	            <% comms_delete_allowed = deletable_comms_stage?(stage) %>
	            <% comms_delete_confirm = "Delete this WIZWIKI COMMS block for #{stage_company_name(stage)} and purge its SMS/email history, generated reports, media, stored files, and vector memory? If this phone/email is added again it will start fresh. This cannot be undone." %>
	            <% if comms_delete_allowed %>
	              <%= button_to "🗑️",
	                delete_comms_command_path(stage),
	                method: :delete,
	                params: { q: @comms_query.presence, status: @comms_status_filter.presence, page: @comms_page.presence }.compact,
	                form_class: "comms-command-inline-form comms-command-remove-form comms-command-delete-form--confirmed",
	                form: { data: { turbo: false, comms_delete_form: "true", comms_confirm_message: comms_delete_confirm } },
	                class: "comms-command-icon-button comms-command-icon-button--delete",
	                title: "Delete comms block",
	                aria: { label: "Delete comms block for #{stage_company_name(stage)}" },
	                data: { comms_confirm_message: comms_delete_confirm } %>
	            <% else %>
	              <%= button_tag "🗑️",
	                type: "button",
	                class: "comms-command-icon-button comms-command-icon-button--delete",
	                disabled: true,
	                title: "Protected source block",
	                aria: { label: "Protected source block for #{stage_company_name(stage)}" } %>
	            <% end %>
            </div>	          </div>
	          <div class="comms-command-stale-timer comms-command-stale-timer--<%= follow_up_timer[:state] %>"
	               data-follow-up-timer
	               data-follow-up-timer-state="<%= follow_up_timer[:state] %>"
	               data-follow-up-timer-due-at="<%= follow_up_timer[:due_at] %>"
	               data-follow-up-timer-prefix="<%= follow_up_timer[:state].to_s == 'capped' ? 'CAP RESETS' : (follow_up_timer[:state].to_s == 'outside_window' ? 'WINDOW IN' : 'STALE IN') %>"
	               data-follow-up-timer-due-label="<%= follow_up_timer[:state].to_s == 'capped' ? 'DAILY CAP RESET' : (follow_up_timer[:state].to_s == 'outside_window' ? 'WINDOW OPEN' : 'STALE NOW') %>"
	               title="<%= follow_up_timer[:detail] %>">
	            <span data-follow-up-timer-label><%= follow_up_timer[:label] %></span>
	          </div>
	          <div class="comms-command-discovery-strip <%= 'comms-command-discovery-strip--complete' if discovery_complete %> <%= 'comms-command-discovery-strip--blocked' if sms_do_not_contact %>"
               style="--discovery-percent: <%= discovery_percent %>%;"
               role="progressbar"
               aria-valuemin="0"
               aria-valuemax="<%= discovery_total %>"
               aria-valuenow="<%= discovery_done %>"
               aria-label="<%= discovery_done %> of <%= discovery_total %> discovery questions complete">
            <span class="comms-command-discovery-fill" style="width: <%= discovery_percent %>%"></span>
            <span class="comms-command-discovery-count"><%= discovery_done %>/<%= discovery_total %> · <%= discovery_percent %>%</span>
          </div>
        </article>
      <% end %>
    <% else %>
      <div class="comms-command-empty-state">
        <h2>No staged comms yet</h2>
        <p>Create a solo block, import a CSV, or wait for the Owner Queue and Storm Watch background lanes to refresh.</p>
        <%= link_to "CREATE SOLO BLOCK", comms_command_path(anchor: "top"), class: "comms-command-profile-link" %>
      </div>
    <% end %>
  </div>
</section>
