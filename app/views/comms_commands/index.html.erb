              </div>
            <% end %>
          <% else %>
            <p class="comms-command-empty">No media uploaded yet.</p>
          <% end %>
        </div>
      </div>
    </details>

    <% if record_claimed_by_me %>
  <details class="comms-command-details rpt-lab-details" <%= "open" if params[:open_ai_lab_stage].to_s == stage.id.to_s %>>
