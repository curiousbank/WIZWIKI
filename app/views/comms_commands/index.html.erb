	                        <%= submit_tag(sms_do_not_contact ? "DO NOT CONTACT" : "COPILOT DRAFT", disabled: sms_do_not_contact, class: "comms-command-autopilot-button comms-command-autopilot-button--copilot #{'comms-command-autopilot-button--blocked' if sms_do_not_contact}", data: { comms_confirm_message: overlay_copilot_confirm, turbo_confirm: overlay_copilot_confirm }) %>
