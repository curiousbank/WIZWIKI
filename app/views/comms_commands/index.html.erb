              <div class="rpt-lab-panel-selectors">
                <label for="report_embedder_<%= audience %>_comms_<%= stage.id %>" class="rpt-lab-control">
                  <span>1 // embedder <b>★ default</b></span>
                  <select id="report_embedder_<%= audience %>_comms_<%= stage.id %>" name="report_embedder_model" class="deal-report-model-select">
