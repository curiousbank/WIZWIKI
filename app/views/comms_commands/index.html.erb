                        </label>
                        <label class="comms-command-runall-model comms-command-runall-model--llm">
                          <span>RUNTIME</span>
                          <span class="comms-command-warp-toggle comms-command-warp-toggle--batch" role="group" aria-label="SMS writer runtime">
                            <% comms_runtime_toggle_options.each do |label, value| %>
                              <% checked = comms_runtime_value.call(run_all_sms_writer_model) == value %>
                              <% runtime_configured = comms_runtime_configured.call(value) %>
                              <% runtime_actual_model = comms_runtime_actual_model.call(value) %>
                              <label class="comms-command-warp-choice <%= 'is-active' if checked %> <%= 'is-unavailable' unless runtime_configured %>" title="<%= "#{label}: #{runtime_actual_model}#{' (endpoint setup required)' unless runtime_configured}" %>">
