                      <option value="<%= model %>" <%= "selected" if model == WizwikiSettings.report_embedder_model %>><%= label %></option>
                    <% end %>
                  </select>
                </label>
                <label for="report_local_model_<%= audience %>_comms_<%= stage.id %>" class="rpt-lab-control" data-rpt-builder-target="<%= audience == "copy_maker" ? "localPrepControl" : nil %>">
                  <span>2 // local LLM <b>★ default</b></span>
                  <select id="report_local_model_<%= audience %>_comms_<%= stage.id %>" name="report_local_model" class="deal-report-model-select">
                    <% report_local_model_options.each do |label, model| %>
                      <option value="<%= model %>" <%= "selected" if model == WizwikiSettings.default_report_lane[:report_local_model] %>><%= label %></option>
                    <% end %>
                  </select>
                </label>
                <label for="report_challenger_<%= audience %>_comms_<%= stage.id %>" class="rpt-lab-control">
                  <span>3 // challenger <b>review</b></span>
                  <select id="report_challenger_<%= audience %>_comms_<%= stage.id %>" name="report_challenger_model" class="deal-report-model-select">
                    <% report_challenger_model_options.each do |label, model| %>
                      <option value="<%= model %>" <%= "selected" if model == WizwikiSettings.default_challenger_model %>><%= label %></option>
                    <% end %>
                  </select>
                </label>
              </div>
              <% if audience == "copy_maker" %>
                <div class="rpt-lab-copy-switches" aria-label="Copy Maker switches">
                  <label class="rpt-lab-switch"><input type="checkbox" name="copy_maker_comm_kit" value="1" checked data-rpt-builder-target="commKitToggle"><span><b>COMM KIT</b><em>3 texts + 2 friendly sales emails.</em></span></label>
                  <div class="rpt-lab-switch rpt-lab-switch--direction" data-rpt-builder-target="commKitDirection">
                    <span><b>COMM KIT DIRECTION</b><span class="mt-2 grid gap-2 sm:grid-cols-2"><label class="flex gap-2 border border-dotted border-fuchsia-200/40 bg-black/30 p-2"><input type="radio" name="copy_maker_comm_kit_direction" value="wizwiki_out" checked class="mt-1 accent-fuchsia-300"><span><strong class="text-fuchsia-100">WIZWIKI OUT</strong><br>WIZWIKI outreach to the business owner.</span></label><label class="flex gap-2 border border-dotted border-cyan-200/40 bg-black/30 p-2"><input type="radio" name="copy_maker_comm_kit_direction" value="client_out" class="mt-1 accent-cyan-300"><span><strong class="text-cyan-100">CLIENT OUT</strong><br>Client-branded campaign copy.</span></label></span></span>
                  </div>
                  <label class="rpt-lab-switch"><input type="checkbox" name="copy_maker_local_prep" value="1" checked data-rpt-builder-target="localPrepToggle"><span><b>LOCAL LLM PREP</b><em>Use selected Qwen model before final payload.</em></span></label>
                </div>
              <% else %>
                <div class="rpt-lab-copy-switches">
                  <label class="rpt-lab-switch"><input type="checkbox" name="report_preflight_scan" value="1"><span><b>👁️ SCAN</b><em>Read images first.</em></span></label>
                  <label class="rpt-lab-switch"><input type="checkbox" name="report_post_review" value="1"><span><b>🧽 POLISH</b><em>Clean text pass.</em></span></label>
                  <label class="rpt-lab-switch"><input type="checkbox" name="report_page_visual_qa" value="1"><span><b>📄 QA</b><em>Check pages.</em></span></label>
                </div>
              <% end %>
              <p class="rpt-lab-panel-note"><%= note %></p>
            </div>
          <% end %>
        </div>
        <button type="submit" class="rpt-lab-create" data-report-timer-target="button">
          <span data-report-timer-target="idle">▶ CREATE <b data-rpt-builder-target="buttonLabel">🤝 CLIENT</b></span>
          <span data-report-timer-target="working" hidden>⏳ CREATE <b data-rpt-builder-target="workingLabel">🤝 CLIENT</b> <b data-report-timer-target="seconds">0s</b></span>
        </button>
      </form>
    </div>
  </details>
<% else %>
  <span class="comms-command-icon-button comms-command-icon-button--disabled" title="Claim this lead before opening AI LAB" aria-label="Claim before RUN">🏃</span>
<% end %>

    <% if report_artifacts.any? %>
