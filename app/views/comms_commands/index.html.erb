              <option value="client">🤝 CLIENT REPORT</option>
              <option value="am">🧭 AM REPORT</option>
              <option value="copy_maker">✒️ COPY</option>
            </select>
          </label>
          <label for="industry_strategy_lens_comms_<%= stage.id %>" class="rpt-lab-mode">
