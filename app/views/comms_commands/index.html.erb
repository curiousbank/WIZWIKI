    <div class="deal-flyout deal-flyout--report rpt-lab-overlay" role="dialog" aria-modal="true" aria-label="Thumper report lab">
      <form action="<%= queue_deal_report_path(comms_record) %>" method="post" class="rpt-lab-form" data-controller="rpt-builder report-timer" data-rpt-builder-client-count-value="<%= client_report_count %>" data-rpt-builder-am-count-value="<%= am_report_count %>" data-rpt-builder-copy-maker-count-value="<%= copy_maker_report_count %>" data-report-timer-deal-id-value="<%= comms_record.id %>" data-report-timer-report-count-value="<%= client_report_count %>" data-report-timer-status-url-value="<%= deal_report_status_path(comms_record) %>" data-report-timer-poll-interval-value="5000" data-report-timer-audience-value="client" data-action="change->rpt-builder#update keydown.esc@window->rpt-builder#close turbo:submit-start->rpt-builder#beforeSubmit turbo:submit-start->report-timer#start turbo:submit-end->report-timer#submitted">
        <input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>" autocomplete="off">
        <div class="rpt-lab-header">
          <div class="rpt-lab-clippy" role="button" tabindex="0" aria-label="Thumper AI Lab help" aria-describedby="comms_rpt_lab_clippy_help_<%= stage.id %>">
            <%= image_tag "autos.png", alt: "Thumper AI Lab helper", class: "rpt-lab-clippy-image" %>
            <span id="comms_rpt_lab_clippy_help_<%= stage.id %>" class="rpt-lab-clippy-bubble" role="tooltip">
              <strong>Thumper AI LAB GUIDE</strong>
              <span>CLIENT REPORT builds the buyer-facing strategy doc and Canva kit. AM REPORT builds internal notes, risks, and next actions. COPYWRITER builds ads, postcards, SMS/email copy, and COMM KIT batches.</span>
              <span>LOCAL LLM PREP lets Qwen digest CRM, media, Fathom, weather, and fine-training context before the final writer. Turn it off for payload-only copy tests.</span>
              <span>COPY POST PAYLOAD chooses the final writer for COPY mode. The Voice Editor tunes the source text Thumper retrieves across reports, /ask, and SMS.</span>
            </span>
          </div>
