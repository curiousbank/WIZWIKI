<% content_for :title, "LEAD GEN" %>
<% comms_close_overlay_js = "event.preventDefault();event.stopPropagation();const details=this.closest('details');if(details){details.open=false;}const url=new URL(window.location.href);url.searchParams.delete('open_sms_stage');url.searchParams.delete('open_email_stage');window.history.replaceState(window.history.state,'',url.pathname+url.search+url.hash);return false;" %>
<% comms_confirm_onsubmit_js = "const s=event&&event.submitter;const clear=()=>{delete this.dataset.turboConfirm;if(s&&s.dataset){delete s.dataset.turboConfirm;}};const m=(s&&(s.dataset.commsConfirmMessage||s.dataset.turboConfirm))||this.dataset.commsConfirmMessage||this.dataset.turboConfirm||'Continue?';if(this.dataset.commsConfirmed==='true'){clear();delete this.dataset.commsConfirmed;return true;}if(confirm(m)){this.dataset.commsConfirmed='true';clear();return true;}return false;" %>
<% comms_native_confirm_js = ->(message) { "const clear=()=>{if(this.dataset){delete this.dataset.turboConfirm;}if(this.form&&this.form.dataset){delete this.form.dataset.turboConfirm;}};if(this.form&&this.form.dataset.commsConfirmed==='true'){clear();return true;}if(confirm(#{message.to_json})){if(this.form){this.form.dataset.commsConfirmed='true';}clear();return true;}return false;" } %>
<% comms_overlay_close_path = comms_command_path(q: @comms_query.presence, status: @comms_status_filter.presence, page: @comms_page.presence) %>
<% email_follow_up = @follow_up_settings.to_h["email"].to_h %>
<% raw_email_follow_up_enabled = ActiveModel::Type::Boolean.new.cast(email_follow_up["enabled"]) %>
<% email_follow_up_preset = email_follow_up["preset"].presence || "normal" %>
<% raw_email_follow_up_cadence = email_follow_up["cadence"].presence || (raw_email_follow_up_enabled ? "weekly" : "off") %>
<% email_follow_up_enabled = raw_email_follow_up_enabled && email_follow_up_preset != "off" && raw_email_follow_up_cadence != "off" %>
<% email_follow_up_cadence = email_follow_up_enabled ? (email_follow_up_preset == "monthly" ? "monthly" : "weekly") : "off" %>
<% email_follow_up_preset_choice = email_follow_up_enabled ? email_follow_up_preset : "off" %>
<% email_follow_up_mode = email_follow_up_enabled ? (email_follow_up["schedule_mode"].presence || "preset") : "preset" %>
<% email_follow_up_plan = email_follow_up_enabled ? (email_follow_up_mode == "custom" ? (email_follow_up["daily_plan"].to_h.presence || comms_email_follow_up_day_plan(email_follow_up_preset)) : comms_email_follow_up_day_plan(email_follow_up_preset)) : comms_email_follow_up_day_plan("off") %>
<% email_follow_up_preset_plans = comms_email_follow_up_preset_day_plans %>
<% email_follow_up_week_options = comms_email_follow_up_monthly_week_options %>
<% email_follow_up_selected_weeks = Array(email_follow_up["selected_weeks"]).map(&:to_s) %>
<% email_follow_up_selected_weeks = email_follow_up_week_options.map { |week| week[:key] } if email_follow_up_preset_choice == "monthly" && email_follow_up_selected_weeks.blank? %>
<% run_all_visible_count = @run_all_visible_eligible_count.to_i %>
<% copilot_visible_count = @copilot_visible_eligible_count.to_i %>
<% csv_lane_purge = @comms_status_filter.to_s.start_with?("csv_import:") %>
<% remove_all_visible_count = (@purge_eligible_count || @remove_all_visible_eligible_count).to_i %>
<% claim_visible_count = @claim_visible_eligible_count.to_i %>
<% bulk_source = @bulk_autopilot_status.to_h["source"].to_h.presence || @bulk_copilot_status.to_h["source"].to_h %>
<% batch_template_settings = @batch_template_settings.to_h.presence || comms_batch_template_settings %>
<% sms_language_settings = @sms_language_settings.to_h.presence || comms_sms_language_settings %>
<% sms_language_enabled = ActiveModel::Type::Boolean.new.cast(sms_language_settings["enabled"]) %>
<% sms_batch_templates = Array(batch_template_settings.dig("templates", "sms")) %>
<% email_batch_templates = Array(batch_template_settings.dig("templates", "email")) %>
<% selected_sms_batch_template_id = batch_template_settings["selected_sms_template_id"].to_s %>
<% selected_email_batch_template_id = batch_template_settings["selected_email_template_id"].to_s %>
<% active_sms_batch_template = comms_batch_template_active("sms").to_h %>
<% active_email_batch_template = comms_batch_template_active("email").to_h %>
<% full_auto_static_note = active_sms_batch_template.present? ? " Static SMS template \"#{active_sms_batch_template["title"]}\" is ON, so FULL AUTO will send that rendered copy instead of dynamic first-copy for this batch." : " Static SMS templates are OFF; dynamic Thumper autopilot will draft normally." %>
<% copilot_static_note = active_sms_batch_template.present? ? " Static SMS template \"#{active_sms_batch_template["title"]}\" is ON, so COPILOT will place that rendered copy into NEXT TEXT for approval." : " Static SMS templates are OFF; dynamic Thumper copilot will draft normally." %>
<% run_all_sms_writer_model = WizwikiSettings.normalize_sms_writer_model(params[:sms_writer_model].presence || bulk_source["sms_writer_model"].presence || WizwikiSettings.default_sms_writer_model) %>
<% run_all_launch_cadence = normalize_run_all_cadence(params[:run_all_cadence].presence || bulk_source["launch_cadence"].presence) %>
<% run_all_launch_cadence_label = comms_run_all_cadence_label(run_all_launch_cadence) %>
<% run_all_page_limit = @comms_page_size.to_i.positive? ? @comms_page_size.to_i : 100 %>
<% comms_runtime_toggle_options = [["LOCAL", "qwen3:8b"], ["WARP", "nvidia:warp"], ["NEMOTRON", "nvidia:nemotron"]] %>
<% comms_runtime_actual_model = ->(runtime) do
  runtime.start_with?("nvidia:") ? WizwikiSettings.sms_writer_cloud_model(runtime).to_s : runtime
end %>
<% comms_runtime_model_label = ->(runtime) do
  actual_model = comms_runtime_actual_model.call(runtime)
  case actual_model
  when "qwen3:8b" then "Qwen 3 8B"
  when "qwen3:30b" then "Qwen 3 30B"
  when "nvidia/nemotron-3-nano-30b-a3b" then "Nemotron 3 Nano 30B"
  when "nvidia/nemotron-3-nano-omni-30b-a3b-reasoning" then "Nemotron 3 Nano Omni"
  else actual_model.sub(/\Anvidia\//, "").tr("-_", " ").squish.titleize.presence || "Not configured"
  end
end %>
<% comms_runtime_configured = ->(runtime) do
  !runtime.start_with?("nvidia:") || WizwikiSettings.sms_writer_cloud_configured?(runtime)
end %>
<% comms_runtime_value = ->(model) do
  normalized = WizwikiSettings.normalize_sms_writer_model(model)
  %w[nvidia:warp nvidia:nemotron].include?(normalized) ? normalized : "qwen3:8b"
end %>
<% run_all_disabled = @stages.blank? || !@twilio_status[:configured] || @run_all_blocked_by_visible_dnc %>
<% copilot_disabled = @stages.blank? %>
<% claim_visible_disabled = claim_visible_count.zero? %>
<% claim_visible_confirm = claim_visible_disabled ? "No unclaimed visible call blocks are available to claim on this page." : "Claim all #{claim_visible_count} call block#{'s' unless claim_visible_count == 1} on this page? They will be claimed for you and moved to Claimed by me." %>
<% run_all_confirm = @run_all_blocked_by_visible_dnc ? "A visible call block is marked DO NOT CONTACT. Filter or hide opt-outs before using FULL AUTO." : "Start FULL AUTO for #{run_all_visible_count} eligible visible call block#{'s' unless run_all_visible_count == 1} on page #{@comms_page} using #{WizwikiSettings.sms_writer_model_label(run_all_sms_writer_model)} at the selected pace? Only the currently visible page is snapshotted, up to #{run_all_page_limit} visible rows. The run keeps fixed call block IDs even if the board later reflows. After launch, each block listens individually; rerun FULL AUTO only to pick up new or autopilot-off blocks. Link-sent, AM support, hold, hidden, complete, opt-out, already-listening, and no-phone blocks are skipped.#{full_auto_static_note}" %>
<% copilot_confirm = copilot_visible_count.zero? ? "COPILOT will re-check this visible page for draftable call blocks at the selected pace. Opt-outs, complete blocks, autopilot-running blocks, already-drafting blocks, and no-phone blocks are skipped. If none are eligible, no drafts are queued. No SMS will be sent.#{copilot_static_note}" : "Queue COPILOT drafts for #{copilot_visible_count} eligible visible call block#{'s' unless copilot_visible_count == 1} on page #{@comms_page} using #{WizwikiSettings.sms_writer_model_label(run_all_sms_writer_model)} at the selected pace? COPILOT snapshots fixed call block IDs from this visible page, only writes NEXT TEXT drafts for human approval, and will not send SMS.#{copilot_static_note}" %>
<% remove_all_confirm = if csv_lane_purge
  "PURGE all #{pluralize(remove_all_visible_count, 'manual CSV WIZWIKI COMMS block')} in this CSV status? Any active CSV loader for this status will be canceled so blocks stop reappearing. Owner Queue and Storm Watch source blocks are protected and will be skipped. Related manual COMMS records are deleted only when no longer used. This cannot be undone."
elsif @comms_status_filter.to_s == "claimed_by_me"
  "PURGE #{pluralize(remove_all_visible_count, 'call block')} from your Claimed by me page? Manual/CSV blocks on this visible page will be deleted. Storm Watch, Owner Queue, and other source-managed blocks will be released from your queue instead of deleting source data. Off-screen blocks on other pages will stay."
else
  "PURGE #{pluralize(remove_all_visible_count, 'manual/CSV WIZWIKI COMMS block')} on this visible page? Owner Queue and Storm Watch source blocks are protected and will be skipped. Off-screen blocks in other lanes/pages will stay. Related manual COMMS records are deleted only when no longer used. This cannot be undone."
end %>
<% bulk_status = @bulk_autopilot_status.to_h %>
<% copilot_bulk_status = @bulk_copilot_status.to_h %>
<% csv_import_status = @csv_import_status.to_h %>
<% csv_import_state = csv_import_status["state"].to_s %>
<% csv_import_active = csv_import_state.in?(%w[queued running]) %>
<% csv_import_rows = csv_import_status["rows"].to_i %>
<% csv_import_processed = csv_import_status["processed"].to_i %>
<% csv_import_percent = csv_import_rows.positive? ? [[(csv_import_processed.to_f / csv_import_rows) * 100, 100].min, 0].max : (csv_import_active ? 12 : 100) %>
<% claim_report_dialog = flash.delete(:comms_claim_report).to_s %>
<% if claim_report_dialog.present? %>
  <script>
    (() => {
      const message = <%= claim_report_dialog.to_json.html_safe %>;
      const showReport = () => {
        const key = `claim-report:${message}`;
        if (window.__wizwikiCommsLastClaimReport === key) return;
        window.__wizwikiCommsLastClaimReport = key;
        window.alert(message);
      };
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", showReport, { once: true });
      } else {
        window.setTimeout(showReport, 0);
      }
    })();
  </script>
<% end %>
<% if csv_import_status.present? %>
  <div class="comms-command-csv-import-backdrop" aria-hidden="true"></div>
  <section class="comms-command-csv-import-dialog" role="dialog" aria-modal="true" aria-label="CSV import progress">
    <p class="comms-command-kicker">CSV loader</p>
    <header class="comms-command-csv-import-head">
      <div>
        <h2><%= (csv_import_status["title"].presence || "CSV call blocks").to_s.truncate(72) %></h2>
        <span><%= csv_import_state.presence || "queued" %> <%= "// #{csv_import_status["filename"].to_s.truncate(42)}" if csv_import_status["filename"].present? %></span>
      </div>
      <% unless csv_import_active %>
        <%= link_to "OK", comms_command_path(status: csv_import_status["status_key"].presence || @comms_status_filter, page: 1), class: "comms-command-csv-import-close" %>
      <% end %>
    </header>
    <div class="comms-command-csv-import-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="<%= csv_import_percent.round %>">
      <span style="width:<%= csv_import_percent.round(1) %>%"></span>
    </div>
    <div class="comms-command-csv-import-stats">
      <b><%= number_with_delimiter(csv_import_processed) %>/<%= csv_import_rows.positive? ? number_with_delimiter(csv_import_rows) : "..." %></b>
      <span>created <%= number_with_delimiter(csv_import_status["created"].to_i) %></span>
      <span>updated <%= number_with_delimiter(csv_import_status["updated"].to_i) %></span>
      <span>skipped <%= number_with_delimiter(csv_import_status["skipped"].to_i) %></span>
      <% if ActiveModel::Type::Boolean.new.cast(csv_import_status["claim_by_current_user"]) %>
        <span>claimed <%= csv_import_status["claimed_by"].presence || "to you" %></span>
      <% end %>
      <span>dupes <%= number_with_delimiter(csv_import_status["duplicate_contact"].to_i) %></span>
      <span>missing <%= number_with_delimiter(csv_import_status["missing_contact"].to_i) %></span>
      <span>errors <%= number_with_delimiter(csv_import_status["errors"].to_i) %></span>
    </div>
    <% if csv_import_status["error"].present? %>
      <p class="comms-command-csv-import-error"><%= csv_import_status["error"].to_s.truncate(220) %></p>
    <% elsif csv_import_state == "canceled" %>
      <p class="comms-command-csv-import-note">Importer canceled for this CSV status. Purged blocks will not keep coming back.</p>
    <% elsif csv_import_active %>
      <p class="comms-command-csv-import-note">Building call blocks in the background. You can leave this page; this window will keep checking in.</p>
    <% else %>
      <p class="comms-command-csv-import-note">Import complete. Open the CSV status to claim or run the blocks.</p>
    <% end %>
  </section>
  <% if csv_import_active %>
    <script>
      window.setTimeout(() => {
        const url = new URL(window.location.href);
        url.searchParams.set("csv_import_job", <%= csv_import_status["job_id"].to_json.html_safe %>);
        window.location.replace(url.toString());
      }, 2500);
    </script>
  <% end %>
<% end %>

<section class="comms-command-shell">
  <section class="comms-command-search comms-command-search--with-menu" aria-label="Search comms">
    <div class="comms-command-search-copy comms-command-search-copy--menus">
      <div class="comms-command-followup-version" aria-label="Follow-Up autopilot version">
        <span>Follow-Up</span>
        <em>autopilot</em>
        <span>v0.02</span>
      </div>
      <div class="comms-command-deck-titlebar comms-command-deck-titlebar--menus comms-command-search-menu">
        <nav class="comms-command-win-menubar comms-command-win-menubar--titlebar" aria-label="Lead generator menus">
        <div class="comms-command-win-menu comms-command-win-menu--file" data-comms-win-menu>
          <button type="button" id="comms-file-menu-trigger" class="comms-command-win-menu-trigger" data-comms-win-menu-trigger aria-haspopup="true" aria-expanded="false" aria-controls="comms-file-menu">File</button>
          <div id="comms-file-menu" class="comms-command-win-menu-panel comms-command-win-menu-panel--wide" aria-labelledby="comms-file-menu-trigger">
            <div class="comms-command-win-flyout comms-command-win-flyout--loader" aria-label="Create comm">
              <div class="comms-command-win-flyout-label" tabindex="0">
                <span>Load Block</span>
                <small>One contact</small>
              </div>
              <div class="comms-command-win-flyout-panel">
              <%= form_with url: create_manual_comms_path, method: :post, class: "comms-command-launcher-form comms-command-launcher-form--solo" do %>
                <%= hidden_field_tag :q, @comms_query if @comms_query.present? %>
                <%= hidden_field_tag :status, @comms_status_filter %>
                <%= hidden_field_tag :page, @comms_page %>
                <%= text_field_tag :contact_label, nil, placeholder: "Name or company", maxlength: 120, class: "comms-command-launcher-input" %>
                <div class="comms-command-input-action">
                  <%= text_field_tag :contact_value, nil, placeholder: "Phone or email", maxlength: 160, class: "comms-command-launcher-input", required: true %>
                  <%= submit_tag "CREATE", class: "comms-command-launcher-submit comms-command-launcher-submit--inline" %>
                </div>
              <% end %>
              </div>
            </div>
            <div class="comms-command-win-flyout comms-command-win-flyout--loader comms-command-win-flyout--csv-loader" aria-label="CSV call block generator">
              <div class="comms-command-win-flyout-label" tabindex="0">
                <span>Load Blocks</span>
                <small>CSV uploader</small>
              </div>
              <div class="comms-command-win-flyout-panel">
                <p class="comms-command-kicker">CSV upload</p>
              <%= form_with url: import_comms_csv_path, method: :post, multipart: true, local: true, data: { turbo: false }, class: "comms-command-launcher-form comms-command-launcher-form--csv" do %>
                <%= text_field_tag :call_csv_title, nil, placeholder: "Optional status title", maxlength: 80, class: "comms-command-launcher-input" %>
                <label class="comms-command-launcher-check">
                  <%= check_box_tag :call_csv_claim_by_me, "1", false %>
                  <span>Claim imported blocks to me</span>
                </label>
                <div class="comms-command-input-action">
                  <%= file_field_tag :call_csv, accept: ".csv,text/csv", required: true, class: "comms-command-launcher-input" %>
                  <%= submit_tag "IMPORT", class: "comms-command-launcher-submit comms-command-launcher-submit--inline" %>
                </div>
              <% end %>
              </div>
            </div>
            <div class="comms-command-win-flyout comms-command-win-flyout--templates" aria-label="Static batch SMS and email templates">
              <div class="comms-command-win-flyout-label" tabindex="0">
                <span>Templates</span>
                <small>Static SMS/email</small>
              </div>
              <div class="comms-command-win-flyout-panel comms-command-win-flyout-panel--templates">
                <%= form_with url: update_comms_batch_templates_path, method: :patch, class: "comms-command-batch-template-form" do %>
                  <%= hidden_field_tag :q, @comms_query.presence %>
                  <%= hidden_field_tag :status, @comms_status_filter %>
                  <%= hidden_field_tag :page, @comms_page %>
                  <header class="comms-command-batch-template-head">
                    <div>
                      <p class="comms-command-kicker">static campaign copy</p>
                      <b>Batch Templates</b>
                    </div>
                    <div class="comms-command-batch-template-status" aria-label="Active template status">
                      <span class="comms-command-batch-template-status-pill">SMS <%= active_sms_batch_template.present? ? active_sms_batch_template["title"].to_s.truncate(22) : "OFF" %></span>
                      <span class="comms-command-batch-template-status-pill">EMAIL <%= active_email_batch_template.present? ? active_email_batch_template["title"].to_s.truncate(22) : "OFF" %></span>
                    </div>
                  </header>
                  <section class="comms-command-batch-template-token-guide" aria-label="Template token guide">
                    <b>Tokens</b>
                    <span>Click a chip to copy it. Paste tokens into SMS or email copy; each call block fills its own value at launch.</span>
                  </section>
                  <div class="comms-command-batch-template-tokens" aria-label="Template tokens">
                    <% comms_batch_template_token_options.each do |label, token| %>
                      <button type="button" title="Copy <%= token %>. Paste it into the template copy." aria-label="Copy <%= label %> token" data-comms-template-token="<%= token %>" onclick="navigator.clipboard&&navigator.clipboard.writeText(this.dataset.commsTemplateToken);this.classList.add('is-copied');window.setTimeout(()=>this.classList.remove('is-copied'),900)">
                        <span><%= label %></span>
                        <code><%= token %></code>
                      </button>
                    <% end %>
                  </div>
                  <section class="comms-command-batch-template-new">
                    <header class="comms-command-batch-template-section-head">
                      <b>Create Template</b>
                      <span>Save reusable batch copy. Copy is required; email templates also need a subject. Leave selection OFF for dynamic Thumper drafting.</span>
                    </header>
                    <label>
                      <span>Type</span>
                      <%= select_tag "batch_templates[new][type]", options_for_select([["SMS", "sms"], ["EMAIL", "email"]]), class: "comms-command-launcher-input" %>
                    </label>
                    <label>
                      <span>Title</span>
                      <%= text_field_tag "batch_templates[new][title]", nil, maxlength: 90, placeholder: "July postcard push", class: "comms-command-launcher-input" %>
                    </label>
                    <label>
                      <span>Subject <em>Email only</em></span>
                      <%= text_field_tag "batch_templates[new][subject]", nil, maxlength: 160, placeholder: "Required for email templates", class: "comms-command-launcher-input" %>
                    </label>
                    <label class="comms-command-batch-template-new-body">
                      <span>Copy <em>Required</em></span>
                      <%= text_area_tag "batch_templates[new][body]", nil, rows: 4, maxlength: 8000, placeholder: "Required: Hi {{first_name}}, ...", class: "comms-command-launcher-input" %>
                    </label>
                    <label class="comms-command-batch-template-activate">
                      <%= check_box_tag "batch_templates[new][activate]", "1", false %>
                      <span>Use this after save</span>
                    </label>
                  </section>
                  <div class="comms-command-batch-template-lists">
                    <section class="comms-command-batch-template-list-card">
                      <header>
                        <b>SMS Templates</b>
                        <label class="comms-command-batch-template-off">
                          <%= radio_button_tag "batch_templates[selected_sms_template_id]", "", selected_sms_batch_template_id.blank? %>
                          <span>OFF</span>
                        </label>
                      </header>
                      <% if sms_batch_templates.blank? %>
                        <p>No SMS templates saved.</p>
                      <% end %>
                      <% sms_batch_templates.each do |template| %>
                        <% template_id = template["id"].to_s %>
                        <article class="comms-command-batch-template-row">
                          <%= hidden_field_tag "batch_templates[templates][sms][#{template_id}][id]", template_id %>
                          <label class="comms-command-batch-template-use">
                            <%= radio_button_tag "batch_templates[selected_sms_template_id]", template_id, selected_sms_batch_template_id == template_id %>
                            <span>Use</span>
                          </label>
                          <%= text_field_tag "batch_templates[templates][sms][#{template_id}][title]", template["title"], maxlength: 90, class: "comms-command-launcher-input", aria: { label: "SMS template title" } %>
                          <%= text_area_tag "batch_templates[templates][sms][#{template_id}][body]", template["body"], rows: 3, maxlength: 1200, class: "comms-command-launcher-input", aria: { label: "SMS template body" } %>
                          <label class="comms-command-batch-template-delete">
                            <%= check_box_tag "batch_templates[templates][sms][#{template_id}][delete]", "1", false %>
                            <span>Delete</span>
                          </label>
                        </article>
                      <% end %>
                    </section>
                    <section class="comms-command-batch-template-list-card">
                      <header>
                        <b>Email Templates</b>
                        <label class="comms-command-batch-template-off">
                          <%= radio_button_tag "batch_templates[selected_email_template_id]", "", selected_email_batch_template_id.blank? %>
                          <span>OFF</span>
                        </label>
                      </header>
                      <% if email_batch_templates.blank? %>
                        <p>No email templates saved.</p>
                      <% end %>
                      <% email_batch_templates.each do |template| %>
                        <% template_id = template["id"].to_s %>
                        <article class="comms-command-batch-template-row">
                          <%= hidden_field_tag "batch_templates[templates][email][#{template_id}][id]", template_id %>
                          <label class="comms-command-batch-template-use">
                            <%= radio_button_tag "batch_templates[selected_email_template_id]", template_id, selected_email_batch_template_id == template_id %>
                            <span>Use</span>
                          </label>
                          <%= text_field_tag "batch_templates[templates][email][#{template_id}][title]", template["title"], maxlength: 90, class: "comms-command-launcher-input", aria: { label: "Email template title" } %>
                          <%= text_field_tag "batch_templates[templates][email][#{template_id}][subject]", template["subject"], maxlength: 160, placeholder: "Subject", class: "comms-command-launcher-input", aria: { label: "Email template subject" } %>
