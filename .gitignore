# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key
/config/application.yml


/app/assets/builds/*
!/app/assets/builds/.keep
# Local deployment and asset sync state.
/.kamal/secrets
/.cloudinary.static
/.cloudinary.static.trash
# Generated text-to-speech audio.
/public/tts/*
!/public/tts/.keep
/public/tts_samples/*
!/public/tts_samples/.keep

# Local preservation files from hotfixes/audits. Keep them on disk until reviewed,
# but do not let them show up as work-in-progress code.
*.bak-*
